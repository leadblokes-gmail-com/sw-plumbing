# ============================================================
#  S & W Plumbing — environment config
#  Copy this file to ".env" and fill in real values.
#  Anything prefixed PUBLIC_ is exposed to the browser (safe for
#  a Formspree form ID — it is meant to be public).
# ============================================================

# Contact form endpoint. Create a free form at https://formspree.io,
# point its notifications to swplumbing@gmail.com, and paste the
# endpoint here (looks like https://formspree.io/f/abcdwxyz).
# If left blank, the form gracefully falls back to "please call us".
PUBLIC_FORMSPREE_ENDPOINT=
