# ============================================================
#  S & W Plumbing — environment config
#  Copy this file to ".env" for local dev, and set the SAME values
#  in Vercel → Project → Settings → Environment Variables for prod.
#  Nothing here is PUBLIC_ — these are all server-side secrets.
# ============================================================

# --- Database (quote submissions) -----------------------------------------
# Provisioned in Vercel → Storage → Create Database → Postgres (Neon).
# The integration adds this automatically in production; for LOCAL dev only,
# paste the connection string here (Neon dashboard → Connection string).
DATABASE_URL=
# Some Vercel/Neon setups expose POSTGRES_URL instead — either works.
# POSTGRES_URL=

# --- Email (Resend) --------------------------------------------------------
# Create a free account at https://resend.com (sign up WITH SWPlumbing73@gmail.com
# so it can send to that inbox without a custom domain), then:
# API Keys → Create → paste the key here.
RESEND_API_KEY=

# Who lead emails + the weekly digest go to (comma-separated for multiple).
LEAD_EMAIL_TO=SWPlumbing73@gmail.com

# Sender. Default uses Resend's shared onboarding sender (works to your own
# Resend-account email with no domain). Once S&W has a domain + it's verified
# in Resend, change to e.g. "S&W Plumbing <leads@swplumbing.com.au>".
LEAD_EMAIL_FROM=S&W Plumbing <onboarding@resend.dev>

# --- Cron protection -------------------------------------------------------
# Any long random string. Set the SAME value in Vercel env vars — Vercel sends
# it as a Bearer token when it triggers the Monday weekly-digest cron, and the
# endpoint rejects anything else. Generate one with:  openssl rand -hex 32
CRON_SECRET=

# --- Image generation (unrelated tooling) ----------------------------------
# Higgsfield AI key for `npm run gen:images` (see scripts/generate-higgsfield.mjs).
HIGGSFIELD_API_KEY=
