---
import Icon from './Icon.astro';
import { credentials, business } from '../data/site';
---
<div class="creds" data-anim-children>
  {
    credentials.map((c) => {
      // Show the real licence/ABN inline only when set; otherwise stay honest.
      let body = c.body;
      if (c.title === 'Certified plumber' && business.licence) body += ` Licence ${business.licence}.`;
      if (c.title === 'Fully insured' && business.abn) body += ` ABN ${business.abn}.`;
      return (
        <div class="creds__card" data-tilt>
          <div class="creds__icon"><Icon name={c.icon} size={27} stroke="#0B1B33" /></div>
          <h3 class="creds__title">{c.title}</h3>
          <p class="creds__body">{body}</p>
        </div>
      );
    })
  }
</div>

<style>
  .creds {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 16px;
  }
  .creds__card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 30px;
    transition: transform 0.25s var(--ease-quint), border-color 0.4s, box-shadow 0.4s;
    transform-style: preserve-3d;
  }
  .creds__card:hover {
    border-color: rgba(255, 106, 26, 0.22);
  }
  .creds__icon {
    width: 52px;
    height: 52px;
    border-radius: 13px;
    background: var(--lime-10);
    border: 1px solid rgba(255, 106, 26, 0.22);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 22px;
    color: var(--lime);
  }
  .creds__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.3rem;
    letter-spacing: -0.01em;
    margin-bottom: 9px;
  }
  .creds__body {
    font-size: 14px;
    color: var(--muted-2);
    line-height: 1.55;
  }
</style>
