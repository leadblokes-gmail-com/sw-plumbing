---
/**
 * Image with a graceful fallback. Renders /assets/<file> and, if the file
 * isn't there yet, swaps to a branded SVG placeholder that shows the filename
 * so you know exactly which photo to drop in. Replace by saving the real image
 * into public/assets/<file> — no code change needed.
 */
interface Props {
  src: string; // e.g. /assets/hot-water.jpg
  alt: string;
  class?: string;
  eager?: boolean;
}
const { src, alt, class: cls = '', eager = false } = Astro.props;
const label = src.split('/').pop() ?? 'image';
const svg = `<svg xmlns='http://www.w3.org/2000/svg' width='800' height='600'><defs><linearGradient id='g' x1='0' y1='0' x2='1' y2='1'><stop offset='0' stop-color='#0b2545'/><stop offset='1' stop-color='#0077c8'/></linearGradient></defs><rect width='800' height='600' fill='url(#g)'/><path d='M400 205 C400 205 328 300 328 362 a72 72 0 0 0 144 0 C472 300 400 205 400 205 Z' fill='rgba(255,255,255,0.22)'/><text x='400' y='476' font-family='Arial, sans-serif' font-size='26' fill='rgba(255,255,255,0.9)' text-anchor='middle'>${label}</text><text x='400' y='512' font-family='Arial, sans-serif' font-size='16' fill='rgba(255,255,255,0.55)' text-anchor='middle'>drop your photo here</text></svg>`;
const placeholder = `data:image/svg+xml,${encodeURIComponent(svg)}`;
---
<img
  src={src}
  alt={alt}
  loading={eager ? 'eager' : 'lazy'}
  decoding="async"
  class:list={['assetimg', cls]}
  data-ph={placeholder}
  onerror="this.onerror=null;this.src=this.dataset.ph;this.classList.add('is-ph');"
/>

<style>
  .assetimg {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
