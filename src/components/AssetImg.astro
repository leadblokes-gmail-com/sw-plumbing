---
/**
 * Image with a graceful fallback. Renders /assets/<file> and, if the file
 * isn't there yet, swaps to a branded SVG placeholder that shows the filename
 * so you know exactly which photo to drop in. Replace by saving the real image
 * into public/assets/<file> — no code change needed.
 */
interface Props {
  src: string; // e.g. /assets/hot-water.jpg
  alt: string;
  class?: string;
  eager?: boolean;
}
const { src, alt, class: cls = '', eager = false } = Astro.props;
// Version tag busts any stale CDN/browser cache of the old (PNG-as-jpg) files
// that some browsers cached before the images were re-encoded to real JPEG.
const versionedSrc = src.startsWith('/assets/') ? `${src}?v=2` : src;
// Clean, text-free premium fallback: a charcoal→green tile with a subtle
// centred droplet. Shown only if the real photo at `src` is missing — never
// exposes filenames or "drop your photo here" UI.
const svg = `<svg xmlns='http://www.w3.org/2000/svg' width='800' height='600'><defs><linearGradient id='g' x1='0' y1='0' x2='1' y2='1'><stop offset='0' stop-color='#101412'/><stop offset='0.55' stop-color='#132a20'/><stop offset='1' stop-color='#0b3d26'/></linearGradient></defs><rect width='800' height='600' fill='url(#g)'/><path d='M400 232 C400 232 336 318 336 374 a64 64 0 0 0 128 0 C464 318 400 232 400 232 Z' fill='none' stroke='#19c463' stroke-width='5' opacity='0.5'/></svg>`;
const placeholder = `data:image/svg+xml,${encodeURIComponent(svg)}`;
---
<img
  src={versionedSrc}
  alt={alt}
  loading={eager ? 'eager' : 'lazy'}
  decoding="async"
  class:list={['assetimg', cls]}
  data-ph={placeholder}
  onerror="this.onerror=null;this.src=this.dataset.ph;this.classList.add('is-ph');"
/>

<style>
  .assetimg {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
