---
/**
 * S & W Plumbing logo.
 *
 * Default: a clean built-in wordmark that mirrors the client's brand — a bold
 * green "S&W" stacked over a black, tracked "PLUMBING". Scales perfectly and
 * adapts to light/dark. If the client's own logo image is saved at
 * /assets/sw-plumbing-logo.png it overrides the built-in wordmark automatically.
 *
 * `chip` sits the logo on a light rounded pill — used on dark backgrounds (footer).
 */
interface Props {
  size?: number; // rendered cap-height of "S&W" in px (drives the whole lockup)
  chip?: boolean;
}
const { size = 30, chip = false } = Astro.props;
---
<span class:list={['logo', { 'logo--chip': chip }]} style={`--logo-h:${size}px`}>
  <img
    src="/assets/sw-plumbing-logo.png"
    alt="S & W Plumbing logo"
    class="logo__img"
    height={size * 1.4}
    decoding="async"
    onerror="this.style.display='none';this.nextElementSibling.style.display='inline-flex';"
  />
  <!-- Built-in wordmark — shown unless a client logo image is present -->
  <span class="logo__lockup" style="display:inline-flex">
    <span class="logo__sw">S&amp;W</span>
    <span class="logo__pl">PLUMBING</span>
  </span>
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    line-height: 1;
  }
  .logo__img {
    display: block;
    width: auto;
  }
  /* On dark backgrounds, sit the whole logo on a clean white pill. */
  .logo--chip .logo__img,
  .logo--chip .logo__lockup {
    background: #fff;
    padding: 9px 16px;
    border-radius: 12px;
  }
  /* --- built-in wordmark --- */
  .logo__lockup {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    line-height: 0.88;
  }
  .logo__sw {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--logo-h);
    letter-spacing: -0.03em;
    color: var(--green);
    line-height: 0.86;
  }
  .logo__pl {
    font-family: var(--font-display);
    font-weight: 600;
    /* size + tracking tuned so PLUMBING spans about the same width as S&W */
    font-size: calc(var(--logo-h) * 0.315);
    letter-spacing: 0.2em;
    text-indent: 0.2em; /* keep it visually centred despite trailing tracking */
    color: var(--ink);
    line-height: 1;
    margin-top: calc(var(--logo-h) * 0.04);
  }
</style>
