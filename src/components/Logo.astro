---
/**
 * S & W Plumbing logo.
 *
 * Renders the real brand logo image from /assets/logo.png when it exists; until
 * the file is dropped in, it gracefully falls back to the built-in droplet
 * wordmark so nothing ever breaks. Save the logo to public/assets/logo.png and
 * it appears everywhere (nav + footer) automatically.
 *
 * `chip` sits the logo on a light rounded pill — use it on dark backgrounds (the
 * footer) so the black "PLUMBING" text stays readable with a single logo file.
 */
interface Props {
  size?: number; // rendered height in px
  chip?: boolean;
}
const { size = 34, chip = false } = Astro.props;
const h = Math.round((size * 38) / 34); // fallback wordmark keeps its aspect ratio
---
<span class:list={['logo', { 'logo--chip': chip }]}>
  <img
    src="/assets/logo.png"
    alt="S & W Plumbing"
    class="logo__img"
    height={size}
    decoding="async"
    onerror="this.style.display='none';this.nextElementSibling.style.display='inline-flex';"
  />
  <!-- Fallback wordmark — only shown if /assets/logo.png isn't there yet -->
  <span class="logo__fallback" style="display:none">
    <svg width={size} height={h} viewBox="0 0 34 38" fill="none" aria-hidden="true">
      <path
        d="M17 1C17 1 4 14.5 4 24.5C4 31.9 9.8 37 17 37C24.2 37 30 31.9 30 24.5C30 14.5 17 1 17 1Z"
        stroke="currentColor"
        stroke-width="2"></path>
      <path
        d="M21.5 18.5C20.6 17.4 19 16.7 17.2 16.7C14.4 16.7 12.5 18.2 12.5 20.3C12.5 24.6 21.8 22.7 21.8 26.9C21.8 29.1 19.7 30.6 16.8 30.6C14.7 30.6 12.9 29.7 12 28.4"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"></path>
    </svg>
    <span class="logo__text">S&nbsp;&amp;&nbsp;W<span> PLUMBING</span></span>
  </span>
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    color: var(--forest);
  }
  .logo__img {
    display: block;
    width: auto;
  }
  /* Light pill so the logo (with its black "PLUMBING") reads on dark backgrounds. */
  .logo--chip .logo__img {
    background: #fff;
    padding: 8px 14px;
    border-radius: 12px;
  }
  .logo__fallback {
    align-items: center;
    gap: 12px;
  }
  .logo__text {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 18px;
    letter-spacing: -0.01em;
    line-height: 1;
    color: inherit;
  }
  .logo__text span {
    color: inherit;
    opacity: 0.6;
    font-weight: 500;
  }
</style>
