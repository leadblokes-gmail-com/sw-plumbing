---
/** S & W droplet wordmark (matches the export). */
interface Props {
  size?: number;
  showText?: boolean;
}
const { size = 34, showText = true } = Astro.props;
const h = Math.round((size * 38) / 34);
---
<span class="logo">
  <svg width={size} height={h} viewBox="0 0 34 38" fill="none" aria-label="S and W Plumbing">
    <path
      d="M17 1C17 1 4 14.5 4 24.5C4 31.9 9.8 37 17 37C24.2 37 30 31.9 30 24.5C30 14.5 17 1 17 1Z"
      stroke="#B6FF3C"
      stroke-width="2"></path>
    <path
      d="M21.5 18.5C20.6 17.4 19 16.7 17.2 16.7C14.4 16.7 12.5 18.2 12.5 20.3C12.5 24.6 21.8 22.7 21.8 26.9C21.8 29.1 19.7 30.6 16.8 30.6C14.7 30.6 12.9 29.7 12 28.4"
      stroke="#B6FF3C"
      stroke-width="2"
      stroke-linecap="round"></path>
  </svg>
  {showText && <span class="logo__text">S&nbsp;&amp;&nbsp;W<span> PLUMBING</span></span>}
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 12px;
  }
  .logo__text {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 18px;
    letter-spacing: -0.01em;
    line-height: 1;
  }
  .logo__text span {
    color: var(--muted-2);
    font-weight: 500;
  }
</style>
