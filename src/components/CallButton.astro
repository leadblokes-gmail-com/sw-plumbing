---
import Icon from './Icon.astro';
import { business } from '../data/site';

interface Props {
  size?: 'sm' | 'md' | 'lg' | 'xl';
  pulse?: boolean;
  label?: string;
  class?: string;
}
const { size = 'md', pulse = false, label, class: cls = '' } = Astro.props;
const text = label ?? `Call ${business.phone}`;
---
<a
  href={business.phoneHref}
  data-magnetic
  class:list={['call-btn', `call-btn--${size}`, { 'call-btn--pulse': pulse }, cls]}
  aria-label={`Call S & W Plumbing on ${business.phone}`}
>
  <Icon name="phone" size={size === 'xl' ? 28 : size === 'lg' ? 24 : 18} />
  <span>{text}</span>
</a>

<style>
  .call-btn {
    display: inline-flex;
    align-items: center;
    gap: 11px;
    background: linear-gradient(135deg, var(--green-bright) 0%, var(--green) 100%);
    color: #fff;
    font-weight: 700;
    border-radius: 999px;
    letter-spacing: -0.01em;
    white-space: nowrap;
    box-shadow: var(--shadow-glow);
    transition: transform 0.3s var(--ease-quint), box-shadow 0.3s, filter 0.3s;
    will-change: transform;
  }
  .call-btn:hover {
    transform: translateY(-2px);
    filter: brightness(1.05);
    box-shadow: 0 26px 52px -18px rgba(0, 166, 81, 0.7);
  }
  .call-btn--sm {
    font-size: 14.5px;
    padding: 11px 20px;
    gap: 9px;
  }
  .call-btn--md {
    font-size: clamp(1rem, 2vw, 1.15rem);
    padding: 16px 28px;
  }
  .call-btn--lg {
    font-size: clamp(1.05rem, 2.4vw, 1.3rem);
    padding: clamp(18px, 3vw, 24px) clamp(30px, 5vw, 46px);
  }
  .call-btn--xl {
    font-size: clamp(1.15rem, 3vw, 1.6rem);
    gap: 14px;
    padding: clamp(20px, 3vw, 26px) clamp(34px, 5vw, 52px);
  }
  .call-btn--pulse {
    animation: swpPulse 2.8s var(--ease-quint) infinite;
  }
  @media (prefers-reduced-motion: reduce) {
    .call-btn--pulse {
      animation: none;
    }
  }
</style>
