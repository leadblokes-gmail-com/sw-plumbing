---
import Logo from './Logo.astro';
import CallButton from './CallButton.astro';
import Icon from './Icon.astro';
import { nav, business } from '../data/site';

const path = Astro.url.pathname.replace(/\/$/, '') || '/';
---
<div id="swp-nav" class="navwrap">
  <!-- Top utility bar -->
  <div class="util">
    <div class="util__inner container">
      <span class="util__left"><Icon name="pin" size={13} /> Birkdale &amp; Bayside Brisbane</span>
      <span class="util__right">
        <a href={business.phoneHref}><Icon name="phone" size={13} /> {business.phone}</a>
        <span class="util__sep" aria-hidden="true">·</span>
        <a href={business.emailHref} class="util__email">{business.email}</a>
      </span>
    </div>
  </div>

  <!-- Main header -->
  <header class="nav">
    <a href="/" class="nav__brand" aria-label="S & W Plumbing — home"><Logo /></a>
    <nav class="nav__links" aria-label="Primary">
      {
        nav.map((item) => {
          const href = item.href.replace(/\/$/, '') || '/';
          const active = href === path;
          return (
            <a href={item.href} class:list={['nav__link', { 'is-active': active }]} aria-current={active ? 'page' : undefined}>
              {item.label}
            </a>
          );
        })
      }
    </nav>
    <CallButton size="sm" class="nav__cta" />
  </header>
</div>

<style>
  .navwrap {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
  }
  /* Utility bar */
  .util {
    background: var(--forest);
    color: var(--cream);
    font-size: 12.5px;
    font-weight: 500;
    padding: 7px var(--pad-x);
  }
  .util__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }
  .util__left,
  .util__right {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: rgba(246, 241, 231, 0.82);
  }
  .util__right a {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color 0.25s;
  }
  .util__right a:hover {
    color: #fff;
  }
  .util__sep {
    color: rgba(246, 241, 231, 0.4);
  }
  @media (max-width: 620px) {
    .util__left {
      display: none;
    }
    .util__inner {
      justify-content: center;
    }
  }
  @media (max-width: 440px) {
    .util__email {
      display: none;
    }
  }
  /* Main header */
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px var(--pad-x);
    background: rgba(246, 241, 231, 0.9);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--line);
  }
  .nav__links {
    display: flex;
    align-items: center;
    gap: 32px;
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
  }
  .nav__link {
    position: relative;
    font-size: 14.5px;
    color: var(--muted);
    font-weight: 500;
    transition: color 0.25s;
  }
  .nav__link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -6px;
    width: 100%;
    height: 2px;
    border-radius: 2px;
    background: var(--brass);
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.35s var(--ease-quint);
  }
  .nav__link:hover {
    color: var(--forest);
  }
  .nav__link:hover::after,
  .nav__link.is-active::after {
    transform: scaleX(1);
  }
  .nav__link.is-active {
    color: var(--forest);
    font-weight: 600;
  }
  @media (prefers-reduced-motion: reduce) {
    .nav__link::after {
      transition: none;
    }
  }
  @media (max-width: 860px) {
    .nav__links {
      display: none;
    }
    .nav :global(.nav__cta) {
      padding: 11px 16px;
    }
  }
</style>
