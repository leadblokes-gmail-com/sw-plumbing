---
/** Branded intro/loading sequence. Fires once per session, skippable, reduced-motion safe.
    Logic lives in motion.ts (intro()). The phone CTA underneath is fully interactive
    immediately — the overlay is purely visual and clears itself in ~2.1s. */
---
<div id="swp-intro" class="intro" aria-hidden="true">
  <div class="intro__inner">
    <svg width="66" height="74" viewBox="0 0 34 38" fill="none">
      <path
        id="swp-intro-drop"
        d="M17 1C17 1 4 14.5 4 24.5C4 31.9 9.8 37 17 37C24.2 37 30 31.9 30 24.5C30 14.5 17 1 17 1Z"
        stroke="#0B1B33"
        stroke-width="2"
        style="stroke-dasharray:210;stroke-dashoffset:210;transition:stroke-dashoffset 0.85s cubic-bezier(0.16,1,0.3,1)"></path>
      <path
        id="swp-intro-s"
        d="M21.5 18.5C20.6 17.4 19 16.7 17.2 16.7C14.4 16.7 12.5 18.2 12.5 20.3C12.5 24.6 21.8 22.7 21.8 26.9C21.8 29.1 19.7 30.6 16.8 30.6C14.7 30.6 12.9 29.7 12 28.4"
        stroke="#0B1B33"
        stroke-width="2"
        stroke-linecap="round"
        style="stroke-dasharray:90;stroke-dashoffset:90;transition:stroke-dashoffset 0.7s cubic-bezier(0.16,1,0.3,1) 0.35s"></path>
    </svg>
    <div id="swp-intro-word" class="intro__word">S &amp; W <span>PLUMBING</span></div>
  </div>
</div>

<style>
  .intro {
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: var(--ink-900);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.95s var(--ease-inout);
  }
  .intro__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
  }
  .intro__word {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 19px;
    letter-spacing: 0.06em;
    opacity: 0;
    transform: translateY(10px);
    transition: opacity 0.6s ease 0.55s, transform 0.7s var(--ease-expo) 0.55s;
  }
  .intro__word span {
    color: var(--muted-2);
  }
  @media (prefers-reduced-motion: reduce) {
    .intro {
      display: none;
    }
  }
</style>
