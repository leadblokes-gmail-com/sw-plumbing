---
import Icon from './Icon.astro';
import { business } from '../data/site';

interface Props {
  sub?: string;
  note?: string;
  points?: string[];
}
const { sub, note, points = [] } = Astro.props;
---
<section class="cta" id="contact-cta">
  <div class="cta__inner container">
    <h2 data-reveal class="cta__title"><slot /></h2>
    {sub && <p data-reveal class="cta__sub">{sub}</p>}
    <div data-reveal class="cta__btns">
      <a href={business.phoneHref} class="cta__call" aria-label={`Call S & W Plumbing on ${business.phone}`}>
        <Icon name="phone" size={20} /> Call {business.phone}
      </a>
      <a href="/contact" class="cta__enquiry">Send enquiry</a>
    </div>
    {
      points.length > 0 && (
        <ul data-reveal class="cta__points">
          {points.map((p) => (
            <li>
              <Icon name="check" size={15} stroke="#0077C8" /> {p}
            </li>
          ))}
        </ul>
      )
    }
    {note && <p data-reveal class="cta__note">{note}</p>}
  </div>
</section>

<style>
  .cta {
    position: relative;
    padding: clamp(56px, 8vw, 104px) var(--pad-x);
    text-align: center;
    background: var(--forest);
    color: var(--cream);
  }
  .cta__inner {
    max-width: 780px;
    margin: 0 auto;
  }
  .cta__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2rem, 5.4vw, 3.6rem);
    line-height: 1.04;
    letter-spacing: -0.025em;
    margin-bottom: 20px;
    color: var(--cream);
  }
  .cta__title :global(.lime) {
    color: var(--brass);
  }
  .cta__sub {
    font-size: clamp(1.02rem, 2.2vw, 1.25rem);
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 34px;
    line-height: 1.55;
  }
  .cta__btns {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 14px;
  }
  .cta__call {
    display: inline-flex;
    align-items: center;
    gap: 11px;
    background: var(--brass);
    color: var(--forest-2);
    font-weight: 700;
    font-size: clamp(1.05rem, 2.4vw, 1.25rem);
    padding: 16px 30px;
    border-radius: 999px;
    transition: transform 0.3s var(--ease-quint), background 0.3s;
  }
  .cta__call:hover {
    transform: translateY(-2px);
    background: #c9ac63;
  }
  .cta__enquiry {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid rgba(255, 255, 255, 0.35);
    color: var(--cream);
    font-weight: 600;
    font-size: clamp(1rem, 2vw, 1.15rem);
    padding: 16px 28px;
    border-radius: 999px;
    transition: border-color 0.3s, background 0.3s;
  }
  .cta__enquiry:hover {
    border-color: var(--cream);
    background: rgba(255, 255, 255, 0.08);
  }
  .cta__points {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px 26px;
    margin-top: 28px;
  }
  .cta__points li {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 14.5px;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9);
  }
  .cta__note {
    margin-top: 20px;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.7);
  }
</style>
