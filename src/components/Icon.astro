};
const inner = paths[name] ?? '';
---
<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  aria-hidden="true"
  class={cls}
  style={stroke !== 'currentColor' ? `color:${stroke}` : undefined}
  set:html={inner}
/>
