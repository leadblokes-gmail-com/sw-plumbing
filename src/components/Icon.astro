  maintenance: '<path d="M14.7 6.3a4 4 0 00-5.5 5.5l-5.5 5.5 1.5 1.5 5.5-5.5a4 4 0 005.5-5.5l-2.3 2.3-1.5-1.5 2.3-2.3z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" fill="none"/>',
