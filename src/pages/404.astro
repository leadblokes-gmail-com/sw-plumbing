---
import Layout from '../layouts/Layout.astro';
import CallButton from '../components/CallButton.astro';
import Icon from '../components/Icon.astro';
---
<Layout
  title="Page not found — S & W Plumbing"
  description="That page sprung a leak. Head back home or give your local bayside plumber a call on 0432 292 371."
>
  <section class="nf">
    <canvas id="swp-hero-canvas" class="nf__canvas"></canvas>
    <div class="nf__veil"></div>
    <div class="nf__inner">
      <div class="nf__code">404</div>
      <h1 class="nf__title">This pipe leads <span>nowhere.</span></h1>
      <p class="nf__sub">That page sprung a leak and we couldn't find it. No dramas — let's get you sorted.</p>
      <div class="nf__ctas">
        <CallButton size="md" pulse />
        <a href="/" class="nf__back" data-magnetic>
          Back to home <Icon name="arrow" size={17} stroke="#00A651" />
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .nf {
    position: relative;
    min-height: 86vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 150px var(--pad-x) 90px;
    text-align: center;
  }
  .nf__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }
  .nf__veil {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: radial-gradient(120% 100% at 50% 0%, rgba(255, 255, 255, 0) 38%, rgba(255, 255, 255, 0.92) 100%);
  }
  .nf__inner {
    position: relative;
    z-index: 2;
    max-width: 700px;
    margin: 0 auto;
  }
  .nf__code {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(5rem, 18vw, 11rem);
    line-height: 0.9;
    color: var(--lime);
    letter-spacing: -0.03em;
    text-shadow: 0 0 60px rgba(0, 166, 81, 0.22);
  }
  .nf__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.8rem, 5vw, 3rem);
    letter-spacing: -0.02em;
    margin-top: 8px;
  }
  .nf__title span {
    color: var(--muted-2);
  }
  .nf__sub {
    margin: 18px auto 0;
    color: var(--muted-2);
    font-size: clamp(1rem, 2.2vw, 1.2rem);
    max-width: 42ch;
    line-height: 1.55;
  }
  .nf__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    justify-content: center;
    margin-top: 36px;
  }
  .nf__back {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    border: 1px solid var(--line-strong);
    color: var(--text);
    font-weight: 600;
    font-size: 1rem;
    padding: 16px 26px;
    border-radius: 999px;
    transition: border-color 0.3s, background 0.3s, transform 0.3s;
    will-change: transform;
  }
  .nf__back:hover {
    border-color: var(--lime);
    background: var(--lime-08);
    transform: translateY(-2px);
  }
</style>
