---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ContactForm from '../components/ContactForm.astro';
import MapPanel from '../components/MapPanel.astro';
import Accordion from '../components/Accordion.astro';
import CtaBand from '../components/CtaBand.astro';
import CallButton from '../components/CallButton.astro';
import Icon from '../components/Icon.astro';
import { business, faqs } from '../data/site';

const details = [
  { icon: 'phoneline', label: 'Phone', value: business.phone, sub: 'Tap to call now', href: business.phoneHref },
  { icon: 'mail', label: 'Email', value: 'Email us', sub: business.email, href: business.emailHref },
  { icon: 'clock', label: 'Hours', value: 'Call to arrange', sub: 'Local response where available' },
  { icon: 'pin', label: 'Service area', value: 'Birkdale & the bay', sub: 'Bayside Brisbane & Redlands' },
];

const trust = ['Clear pricing before work starts', 'Clean, tidy work', 'Local to Birkdale', 'Call for the fastest time'];

const faqSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];
---
<Layout
  title="Contact S & W Plumbing — Call 0432 292 371 | Birkdale & Bayside Brisbane"
  description="Get in touch with your local plumber. Call 0432 292 371 for bayside plumbing, or send the details and we'll be in touch. Birkdale, QLD — Bayside Brisbane & the Redlands."
  schema={faqSchema}
>
  <!-- ===== HERO ===== -->
  <section class="chero">
    <canvas id="swp-hero-canvas" class="chero__canvas"></canvas>
    <div class="chero__veil"></div>
    <div class="chero__inner">
      <div data-hero class="badge">
        <span class="badge__dot"></span>
        <span>Get in touch · Bayside Brisbane</span>
      </div>
      <h1 class="chero__title hero-mask">
        <span class="reveal-line"><span>Let's get it</span></span>
        <span class="reveal-line"><span><em class="kinetic">sorted.</em></span></span>
      </h1>
      <p data-hero class="chero__sub">Call now for fast bayside plumbing.</p>
      <div data-hero class="chero__cta"><CallButton size="xl" pulse /></div>
      <p data-hero class="chero__note">Tap to call now</p>
    </div>
  </section>

  <!-- ===== QUICK DETAILS ===== -->
  <Section border={false} class="details-section">
    <div class="details" data-anim-children>
      {
        details.map((d) => {
          const Tag = d.href ? 'a' : 'div';
          return (
            <Tag href={d.href} class="detail" data-tilt>
              <div class="detail__icon"><Icon name={d.icon} size={25} stroke="#0F2F28" /></div>
              <div class="detail__label">{d.label}</div>
              <div class="detail__value">{d.value}</div>
              <div class="detail__sub">{d.sub}</div>
            </Tag>
          );
        })
      }
    </div>
  </Section>

  <!-- ===== FORM + MAP ===== -->
  <Section tint>
    <div class="contact-grid">
      <div data-reveal>
        <div class="eyebrow">Send a message</div>
        <h2 class="h2 contact__h2">Or drop us the details.</h2>
        <p class="contact__lead">Calling is fastest. For non-urgent jobs, send the details below and we'll be in touch.</p>

        <ul class="trust-strip" aria-label="How we work">
          {trust.map((t) => <li><Icon name="check" size={15} stroke="#0F2F28" /> {t}</li>)}
        </ul>

        <ContactForm />
      </div>

      <div data-reveal>
        <div class="eyebrow">Where we're based</div>
        <h2 class="h2 contact__h2">Birkdale, QLD.</h2>
        <div class="contact__map"><MapPanel variant="mini" /></div>
        <p class="contact__map-note">Map is indicative — we come to you, anywhere across bayside Brisbane and the Redlands.</p>
      </div>
    </div>
  </Section>

  <!-- ===== FAQ ===== -->
  <Section>
    <div class="faq-wrap">
      <SectionHeading eyebrow="Good to know" max="820px">Quick questions.</SectionHeading>
      <Accordion items={faqs} />
    </div>
  </Section>

  <CtaBand>
    One call and<br />it's <span class="lime">sorted.</span>
  </CtaBand>
</Layout>

<style>
  /* HERO */
  .chero {
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 128px var(--pad-x) 64px;
    background: linear-gradient(180deg, var(--cream) 0%, var(--cream-2) 100%);
  }
  .chero__canvas {
    display: none;
  }
  .chero__veil {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: radial-gradient(120% 100% at 50% 0%, rgba(246, 241, 231, 0) 36%, rgba(246, 241, 231, 0.92) 100%);
  }
  .chero__inner {
    position: relative;
    z-index: 2;
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
    text-align: center;
  }
  .chero__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.8rem, 9vw, 6.4rem);
    line-height: 0.95;
    letter-spacing: -0.025em;
    margin: 0 auto;
    max-width: 13ch;
  }
  .chero__title :global(em) {
    font-style: normal;
    color: var(--lime);
  }
  .chero__sub {
    margin: 24px auto 0;
    font-size: clamp(1.1rem, 2.4vw, 1.45rem);
    color: var(--muted-2);
    max-width: 34ch;
    line-height: 1.5;
    font-weight: 500;
  }
  .chero__cta {
    margin-top: 40px;
    display: flex;
    justify-content: center;
  }
  .chero__note {
    margin-top: 18px;
    font-size: 13.5px;
    color: var(--muted-2);
  }
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 7px 14px;
    border: 1px solid var(--line);
    background: var(--card);
    backdrop-filter: blur(10px);
    border-radius: 999px;
    margin-bottom: 28px;
    font-size: 12.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted-2);
    font-weight: 600;
  }
  .badge__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--lime);
    box-shadow: 0 0 10px var(--lime);
  }

  /* DETAILS */
  .details {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 16px;
  }
  .detail {
    display: block;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 30px;
    transition: transform 0.25s var(--ease-quint), border-color 0.4s, box-shadow 0.4s;
    transform-style: preserve-3d;
  }
  .detail:hover {
    border-color: rgba(185, 154, 82, 0.22);
  }
  .detail__icon {
    width: 50px;
    height: 50px;
    border-radius: 13px;
    background: var(--lime-10);
    border: 1px solid rgba(185, 154, 82, 0.22);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 22px;
    color: var(--lime);
  }
  .detail__label {
    font-size: 12px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--lime-dark);
    font-weight: 700;
    margin-bottom: 8px;
  }
  .detail__value {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.3rem;
    letter-spacing: -0.01em;
    word-break: break-word;
  }
  .detail__sub {
    font-size: 13.5px;
    color: var(--muted-2);
    margin-top: 6px;
  }

  /* FORM + MAP */
  .contact-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 40px;
    align-items: start;
  }
  .contact__h2 {
    font-size: clamp(1.9rem, 4.4vw, 3rem);
    margin: 16px 0 12px;
  }
  .contact__lead {
    font-size: 14.5px;
    color: var(--muted-2);
    line-height: 1.55;
    margin-bottom: 22px;
  }
  .trust-strip {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 10px 18px;
    margin-bottom: 28px;
  }
  .trust-strip li {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-size: 13.5px;
    font-weight: 600;
    color: var(--text);
  }
  .contact__map {
    margin-top: 8px;
  }
  .contact__map-note {
    font-size: 13.5px;
    color: var(--muted-2);
    margin-top: 16px;
    line-height: 1.5;
  }

  .faq-wrap {
    max-width: 820px;
    margin: 0 auto;
  }
</style>
