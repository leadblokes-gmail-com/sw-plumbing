---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CtaBand from '../components/CtaBand.astro';
import Icon from '../components/Icon.astro';
import { suburbs, business } from '../data/site';
---
<Layout
  title="Service Areas — Bayside Brisbane & the Redlands | S & W Plumbing"
  description="Based near Birkdale, covering Wellington Point, Cleveland, Capalaba, Ormiston, Victoria Point, Wynnum, Redland Bay and across the Redlands. General plumbing, repairs and maintenance. Call 0432 292 371."
>
  <PageHero
    eyebrow="Service areas · Redlands & bay"
    sub="Based near Birkdale, S&W Plumbing helps homes, rentals and small businesses across the bay with general plumbing, repairs and maintenance."
    minh="56vh"
  >
    <span class="reveal-line"><span>Plumber across Birkdale,</span></span>
    <span class="reveal-line"><span>Bayside Brisbane and the <em class="kinetic">Redlands.</em></span></span>
  </PageHero>

  <!-- Suburb cards -->
  <Section>
    <SectionHeading eyebrow="Suburbs we cover" max="640px">Find your suburb.</SectionHeading>
    <div class="areas" data-anim-children>
      {
        suburbs.map((s) => (
          <div class:list={['area', { 'area--hq': s.hq }]}>
            <div class="area__head">
              <h3 class="area__name">{s.name}</h3>
              {s.hq && <span class="area__tag">Home base</span>}
            </div>
            <p class="area__desc">General plumbing, repairs and maintenance</p>
            <a href={business.phoneHref} class="area__call">
              Call for availability <Icon name="arrow" size={13} stroke="#B6FF3C" />
            </a>
          </div>
        ))
      }
    </div>
    <p data-reveal class="areas__note">
      Don't see your suburb? If you're near Bayside Brisbane or the Redlands, call and we'll confirm
      availability.
    </p>
  </Section>

  <CtaBand sub="A quick call is the fastest way to check we cover you and book a time.">
    Not sure if we reach you?<br /><span class="lime">Give us a call.</span>
  </CtaBand>
</Layout>

<style>
  .areas {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(230px, 1fr));
    gap: 14px;
  }
  .area {
    display: flex;
    flex-direction: column;
    gap: 10px;
    background: var(--ink-800);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 22px;
    transition: border-color 0.3s, transform 0.3s var(--ease-quint);
  }
  .area:hover {
    border-color: rgba(182, 255, 60, 0.4);
    transform: translateY(-2px);
  }
  .area--hq {
    border-color: rgba(182, 255, 60, 0.3);
    background: var(--lime-08);
  }
  .area__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }
  .area__name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.2rem;
    letter-spacing: -0.01em;
  }
  .area__tag {
    font-size: 10.5px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
    color: var(--ink-900);
    background: var(--lime);
    padding: 4px 9px;
    border-radius: 999px;
  }
  .area__desc {
    font-size: 13.5px;
    color: var(--muted-2);
    line-height: 1.5;
  }
  .area__call {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 700;
    color: var(--lime);
    margin-top: auto;
  }
  .areas__note {
    margin-top: 32px;
    font-size: 15px;
    color: var(--muted-2);
    line-height: 1.6;
    max-width: 56ch;
  }
</style>
