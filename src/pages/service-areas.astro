---
import Layout from '../layouts/Layout.astro';
import PageHero from '../components/PageHero.astro';
import Section from '../components/Section.astro';
import SectionHeading from '../components/SectionHeading.astro';
import CtaBand from '../components/CtaBand.astro';
import Icon from '../components/Icon.astro';
import { serviceAreaGroups, business } from '../data/site';
---
<Layout
  title="Service Areas — Bayside Brisbane & the Redlands | S & W Plumbing"
  description="Based in Birkdale, covering the Redlands, Bayside Brisbane, Brisbane's south-east and the northern Logan corridor — roughly 40km south-east of Birkdale. Cleveland, Capalaba, Wynnum, Carindale, Springwood, Redland Bay and more. Call 0432 292 371."
>
  <PageHero
    eyebrow="Service areas · Redlands & bay"
    sub="Based near Birkdale, S&W Plumbing helps homes, rentals and small businesses across the bay with general plumbing, repairs and maintenance."
    minh="56vh"
  >
    <span class="reveal-line"><span>Plumber across Birkdale,</span></span>
    <span class="reveal-line"><span>Bayside Brisbane and the <em class="kinetic">Redlands.</em></span></span>
  </PageHero>

  <!-- Suburb tabs by region -->
  <Section>
    <SectionHeading eyebrow="Suburbs we cover" max="640px">Find your area.</SectionHeading>

    <div class="tabs" data-reveal>
      <!-- Tab buttons -->
      <div class="tabs__bar" role="tablist" aria-label="Service area regions">
        {
          serviceAreaGroups.map((g, i) => (
            <button
              type="button"
              role="tab"
              id={`tab-${i}`}
              class:list={['tabs__btn', { 'is-active': i === 0 }]}
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-controls={`panel-${i}`}
              tabindex={i === 0 ? '0' : '-1'}
            >
              {g.region}
              <span class="tabs__count">{g.suburbs.length}</span>
            </button>
          ))
        }
      </div>

      <!-- Tab panels -->
      {
        serviceAreaGroups.map((g, i) => (
          <div
            id={`panel-${i}`}
            role="tabpanel"
            aria-labelledby={`tab-${i}`}
            class:list={['tabs__panel', { 'is-active': i === 0 }]}
            hidden={i !== 0}
          >
            <p class="tabs__blurb">{g.blurb}</p>
            <ul class="chips">
              {g.suburbs.map((name) => (
                <li class="chip">
                  <span class="chip__dot" />
                  {name}
                </li>
              ))}
            </ul>
            {g.note && <p class="tabs__note"><Icon name="pin" size={15} stroke="#00A651" /> {g.note}</p>}
          </div>
        ))
      }
    </div>

    <p data-reveal class="areas__note">
      Don't see your suburb? It may still be in range — we cover roughly 40km south-east of Birkdale.
      <a href={business.phoneHref} class="areas__note-link">Call {business.phone}</a> and we'll confirm.
    </p>
  </Section>

  <CtaBand sub="A quick call is the fastest way to check we cover you and book a time.">
    Not sure if we reach you?<br /><span class="lime">Give us a call.</span>
  </CtaBand>
</Layout>

<style>
  .tabs {
    margin-top: 8px;
  }
  /* Tab bar */
  .tabs__bar {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    padding-bottom: 22px;
    border-bottom: 1px solid var(--line);
  }
  .tabs__btn {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    background: var(--ink-800);
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 11px 18px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 0.98rem;
    color: var(--muted);
    cursor: pointer;
    transition: border-color 0.25s, color 0.25s, background 0.25s, transform 0.2s var(--ease-quint);
  }
  .tabs__btn:hover {
    border-color: rgba(0, 166, 81, 0.35);
    color: var(--text);
    transform: translateY(-1px);
  }
  .tabs__btn.is-active {
    background: var(--navy);
    border-color: var(--navy);
    color: #fff;
  }
  .tabs__count {
    font-size: 12px;
    font-weight: 700;
    line-height: 1;
    padding: 3px 7px;
    border-radius: 999px;
    background: var(--lime-12);
    color: var(--lime-dark);
  }
  .tabs__btn.is-active .tabs__count {
    background: var(--lime);
    color: var(--ink-900);
  }
  /* Panels */
  .tabs__panel {
    padding-top: 26px;
    animation: tabIn 0.4s var(--ease-quint);
  }
  .tabs__panel[hidden] {
    display: none;
  }
  @keyframes tabIn {
    from { opacity: 0; transform: translateY(8px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .tabs__blurb {
    font-size: 15px;
    color: var(--muted-2);
    margin-bottom: 20px;
    max-width: 56ch;
  }
  .chips {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(190px, 1fr));
    gap: 10px;
  }
  .chip {
    display: flex;
    align-items: center;
    gap: 10px;
    background: var(--ink-800);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 14px 16px;
    font-weight: 600;
    font-size: 0.98rem;
    color: var(--text);
    transition: border-color 0.25s, transform 0.2s var(--ease-quint);
  }
  .chip:hover {
    border-color: rgba(0, 166, 81, 0.3);
    transform: translateY(-2px);
  }
  .chip__dot {
    width: 8px;
    height: 8px;
    flex-shrink: 0;
    border-radius: 50%;
    background: var(--lime);
    box-shadow: 0 0 8px rgba(0, 166, 81, 0.5);
  }
  .tabs__note {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 22px;
    font-size: 14px;
    color: var(--muted-2);
    background: var(--lime-08);
    border: 1px solid rgba(0, 166, 81, 0.2);
    border-radius: var(--radius);
    padding: 14px 16px;
    line-height: 1.5;
  }
  .areas__note {
    margin-top: 34px;
    font-size: 15px;
    color: var(--muted-2);
    line-height: 1.6;
    max-width: 60ch;
  }
  .areas__note-link {
    color: var(--lime);
    font-weight: 700;
    white-space: nowrap;
  }
</style>

<script>
  // Tabbed service-area regions: click or keyboard (←/→) to switch.
  (() => {
    const setup = () => {
      const tabs = Array.from(document.querySelectorAll('.tabs__btn'));
      const panels = Array.from(document.querySelectorAll('.tabs__panel'));
      if (!tabs.length) return;

      const activate = (idx: number, focus = true) => {
        tabs.forEach((t, i) => {
          const on = i === idx;
          t.classList.toggle('is-active', on);
          t.setAttribute('aria-selected', on ? 'true' : 'false');
          t.setAttribute('tabindex', on ? '0' : '-1');
          const panel = panels[i];
          if (panel) {
            panel.classList.toggle('is-active', on);
            if (on) panel.removeAttribute('hidden');
            else panel.setAttribute('hidden', '');
          }
        });
        if (focus) (tabs[idx] as HTMLElement).focus();
      };

      tabs.forEach((tab, i) => {
        tab.addEventListener('click', () => activate(i, false));
        tab.addEventListener('keydown', (e: KeyboardEvent) => {
          if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
            e.preventDefault();
            activate((i + 1) % tabs.length);
          } else if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
            e.preventDefault();
            activate((i - 1 + tabs.length) % tabs.length);
          } else if (e.key === 'Home') {
            e.preventDefault();
            activate(0);
          } else if (e.key === 'End') {
            e.preventDefault();
            activate(tabs.length - 1);
          }
        });
      });
    };
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', setup);
    else setup();
  })();
</script>
