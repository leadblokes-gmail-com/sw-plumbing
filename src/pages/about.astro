---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Credentials from '../components/Credentials.astro';
import MapPanel from '../components/MapPanel.astro';
import Reviews from '../components/Reviews.astro';
import CtaBand from '../components/CtaBand.astro';
import CallButton from '../components/CallButton.astro';
import Icon from '../components/Icon.astro';
import { reviews, googleRating } from '../data/site';
const showReviews = reviews.length > 0 || !!googleRating;

const values = [
  { n: '01', title: 'Honesty', body: "Straight answers and fair prices. If you don't need it, we'll tell you." },
  { n: '02', title: 'Quality workmanship', body: "Done to code, done to last. We'd rather do it once and do it right." },
  { n: '03', title: 'Respect for your home', body: 'Boots off, drop sheets down, mess cleaned up. We treat it like our own.' },
  { n: '04', title: 'Fast response', body: "Local means quick. When something's gone wrong, you don't want to wait." },
];
---
<Layout
  title="About S & W Plumbing — Your Local Birkdale Plumber"
  description="A new name with an old-school standard. Certified, straight-talking plumbing for Birkdale and bayside Brisbane — turn up on time, quote upfront, leave it tidy. Call 0432 292 371."
>
  <!-- ===== HERO ===== -->
  <section class="ahero">
    <canvas id="swp-hero-canvas" class="ahero__canvas"></canvas>
    <div class="ahero__veil"></div>
    <div class="ahero__inner container">
      <div>
        <div data-hero class="badge">
          <span class="badge__dot"></span>
          <span>About S &amp; W Plumbing</span>
        </div>
        <h1 class="ahero__title">Your local <span>bayside</span> plumber.</h1>
        <p data-hero class="ahero__sub">Certified, straight-talking, and proud to look after Birkdale and the bay.</p>
        <div data-hero class="ahero__cta"><CallButton size="md" pulse /></div>
      </div>
      <div data-hero class="ahero__media">
        <div class="ahero__frame" data-tilt>
          <picture>
            <source srcset="/images/about-founder.webp" type="image/webp" />
            <img
              src="/images/about-founder.png"
              alt="S & W Plumbing — working on a hot water unit in bayside Brisbane"
              width="720"
              height="900"
              loading="eager"
              fetchpriority="high"
              decoding="async"
            />
          </picture>
          <span class="ahero__corner ahero__corner--tl"></span>
          <span class="ahero__corner ahero__corner--br"></span>
        </div>
        <div class="ahero__pill">
          <span class="badge__dot"></span>
          <span>Birkdale, QLD</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== STORY ===== -->
  <Section>
    <div class="story">
      <div data-reveal class="eyebrow story__eyebrow">Why I started S &amp; W</div>
      <div class="story__body">
        <p data-reveal>I started S &amp; W because I was sick of seeing people mucked around.</p>
        <p data-reveal class="muted">Late tradies. Vague quotes. A bigger bill than the one you agreed to.</p>
        <p data-reveal>
          So I do it the way it should be done — <span class="lime">turn up when I say I will, quote it upfront, and leave the place tidy.</span>
        </p>
        <p data-reveal class="muted">No surprises. Just honest, certified plumbing done properly, for my own community here on the bay.</p>
      </div>
      <div data-reveal class="story__sign">
        <div class="story__rule"></div>
        <span>The S &amp; W team</span>
      </div>
    </div>
  </Section>

  <!-- ===== CREDENTIALS ===== -->
  <Section tint>
    <SectionHeading eyebrow="Why trust us" max="600px">No reviews yet — but plenty to stand on.</SectionHeading>
    <p data-reveal class="creds-intro">We're new, and we won't pretend otherwise. What we can promise is the stuff that actually matters.</p>
    <Credentials />
  </Section>

  <!-- ===== VALUES ===== -->
  <Section class="values" clip>
    <div data-parallax-bg class="values__glow"></div>
    <div class="values__content">
      <SectionHeading eyebrow="What we stand for" max="600px">Four things we won't budge on.</SectionHeading>
      <div class="values__grid" data-anim-children>
        {
          values.map((v) => (
            <div class="values__card">
              <div class="values__num">{v.n}</div>
              <h3 class="values__title">{v.title}</h3>
              <p class="values__body">{v.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </Section>

  <!-- ===== REVIEWS (only renders once real reviews are added) ===== -->
  {showReviews && (
    <Section class="reviews-section"><Reviews /></Section>
  )}

  <!-- ===== LOCAL ANGLE ===== -->
  <Section>
    <div class="local">
      <div data-reveal class="local__copy">
        <div class="eyebrow">Local angle</div>
        <h2 class="h2 local__title">Proud to serve bayside Brisbane.</h2>
        <p class="local__text">
          This is home. We live and work on the bay, so when you call S &amp; W you're getting a neighbour who
          knows the area — not a call centre three suburbs of traffic away.
        </p>
        <a href="/service-areas" class="btn-ghost" data-magnetic>
          See our service areas <Icon name="arrow" size={17} stroke="#B6FF3C" />
        </a>
      </div>
      <div data-reveal><MapPanel variant="teaser" /></div>
    </div>
  </Section>

  <CtaBand sub="No call centres, no runaround. Just a certified bayside plumber on the other end.">
    Give your local plumber<br />a <span class="lime">call.</span>
  </CtaBand>
</Layout>

<style>
  /* HERO */
  .ahero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 150px var(--pad-x) 70px;
  }
  .ahero__canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
  }
  .ahero__veil {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: radial-gradient(120% 100% at 30% 10%, rgba(10, 12, 14, 0) 35%, rgba(10, 12, 14, 0.92) 100%);
  }
  .ahero__inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: clamp(40px, 6vw, 72px);
    align-items: center;
  }
  .ahero__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.5rem, 6.5vw, 4.8rem);
    line-height: 0.97;
    letter-spacing: -0.025em;
  }
  .ahero__title span {
    color: var(--lime);
  }
  .ahero__sub {
    margin-top: 24px;
    font-size: clamp(1.05rem, 2.2vw, 1.35rem);
    color: var(--muted-2);
    max-width: 42ch;
    line-height: 1.55;
    font-weight: 500;
  }
  .ahero__cta {
    margin-top: 34px;
  }
  .ahero__media {
    position: relative;
  }
  .ahero__frame {
    position: relative;
    border: 1px solid rgba(182, 255, 60, 0.4);
    border-radius: 26px;
    padding: 10px;
    background: linear-gradient(160deg, rgba(182, 255, 60, 0.08), rgba(20, 24, 28, 0.4));
    box-shadow: 0 0 70px -22px rgba(182, 255, 60, 0.5);
    transition: transform 0.25s var(--ease-quint);
    transform-style: preserve-3d;
  }
  .ahero__frame picture {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: 18px;
    overflow: hidden;
  }
  .ahero__frame img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .ahero__corner {
    position: absolute;
    width: 34px;
    height: 34px;
  }
  .ahero__corner--tl {
    top: -1px;
    left: -1px;
    border-top: 2px solid var(--lime);
    border-left: 2px solid var(--lime);
    border-radius: 26px 0 0 0;
  }
  .ahero__corner--br {
    bottom: -1px;
    right: -1px;
    border-bottom: 2px solid var(--lime);
    border-right: 2px solid var(--lime);
    border-radius: 0 0 26px 0;
  }
  .ahero__pill {
    position: absolute;
    bottom: 22px;
    left: 22px;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 9px 15px;
    border-radius: 999px;
    background: rgba(10, 12, 14, 0.78);
    backdrop-filter: blur(10px);
    border: 1px solid var(--line);
    font-size: 13px;
    font-weight: 700;
  }

  /* badge (local) */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 7px 14px;
    border: 1px solid var(--line);
    background: rgba(20, 24, 28, 0.6);
    backdrop-filter: blur(10px);
    border-radius: 999px;
    margin-bottom: 28px;
    font-size: 12.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted-2);
    font-weight: 600;
  }
  .badge__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--lime);
    box-shadow: 0 0 10px var(--lime);
  }
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    border: 1px solid var(--line-strong);
    color: var(--text);
    font-weight: 600;
    font-size: 1rem;
    padding: 15px 26px;
    border-radius: 999px;
    transition: border-color 0.3s, background 0.3s, transform 0.3s;
    will-change: transform;
  }
  .btn-ghost:hover {
    border-color: var(--lime);
    background: var(--lime-08);
    transform: translateY(-2px);
  }

  /* STORY */
  .story {
    max-width: 820px;
    margin: 0 auto;
  }
  .story__eyebrow {
    margin-bottom: 28px;
  }
  .story__body {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(1.6rem, 3.6vw, 2.5rem);
    line-height: 1.28;
    letter-spacing: -0.015em;
  }
  .story__body p {
    margin-bottom: 8px;
  }
  .story__body .muted {
    color: var(--muted-2);
  }
  .story__body .lime {
    color: var(--lime);
  }
  .story__sign {
    margin-top: 38px;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .story__rule {
    height: 1px;
    width: 48px;
    background: var(--lime);
  }
  .story__sign span {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.05rem;
  }

  .creds-intro {
    margin: -34px 0 40px;
    font-size: 15px;
    color: var(--muted-2);
    max-width: 600px;
  }

  /* VALUES */
  .values {
    position: relative;
    overflow: hidden;
  }
  .values__glow {
    position: absolute;
    top: -20%;
    left: -10%;
    width: 60%;
    height: 140%;
    z-index: 0;
    background: radial-gradient(circle, rgba(127, 203, 0, 0.1), rgba(10, 12, 14, 0) 65%);
    pointer-events: none;
  }
  .values__content {
    position: relative;
    z-index: 1;
  }
  .values__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 16px;
  }
  .values__card {
    background: rgba(20, 24, 28, 0.5);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 30px;
  }
  .values__num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 2.4rem;
    color: var(--lime);
    line-height: 1;
    margin-bottom: 18px;
  }
  .values__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.4rem;
    margin-bottom: 10px;
    letter-spacing: -0.01em;
  }
  .values__body {
    font-size: 14px;
    color: var(--muted-2);
    line-height: 1.55;
  }

  /* LOCAL ANGLE */
  .local {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 48px;
    align-items: center;
  }
  .local__title {
    margin: 16px 0 20px;
  }
  .local__text {
    font-size: 16px;
    color: var(--muted-2);
    line-height: 1.6;
    max-width: 42ch;
    margin-bottom: 30px;
  }
</style>
