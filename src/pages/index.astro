---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import SectionHeading from '../components/SectionHeading.astro';
import TrustBar from '../components/TrustBar.astro';
import Reviews from '../components/Reviews.astro';
import JobGallery from '../components/JobGallery.astro';
import MapPanel from '../components/MapPanel.astro';
import CallButton from '../components/CallButton.astro';
import CtaBand from '../components/CtaBand.astro';
import Icon from '../components/Icon.astro';
import { problems, business, reviews, jobs } from '../data/site';

const why = [
  { icon: 'shield', title: 'Certified & insured', body: "A fully licensed, certified plumber on every job. The work is done to code and it's done to last." },
  { icon: 'bolt', title: 'Fast bayside response', body: "Local to Birkdale and the bay, so we're not driving across Brisbane to get to you. Call and we'll move." },
  { icon: 'dollar', title: 'Upfront honest pricing', body: 'You get the price before the work starts. No nasty surprises on the invoice — just a fair, honest quote.' },
];

---
<Layout
  title="S&W Plumbing | Plumber Birkdale & Bayside Brisbane"
  description="Certified local plumber servicing Birkdale, Wynnum, Cleveland, Wellington Point and Bayside Brisbane. Leaks, taps, toilets, hot water and general plumbing repairs. Upfront pricing, fast response — call 0432 292 371."
  intro={true}
>
  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero__media" aria-hidden="true">
      <img src="/images/hero-bg.webp" alt="" width="1920" height="1080" fetchpriority="high" />
    </div>
    <div class="hero__glow" aria-hidden="true"></div>
    <div class="hero__veil hero__veil--top"></div>
    <div class="hero__veil hero__veil--bottom"></div>

    <div class="hero__inner">
      <div data-hero class="badge">
        <span class="badge__dot"></span>
        <span>Certified plumber · Birkdale &amp; Bayside Brisbane</span>
      </div>

      <h1 class="hero__title hero-mask">
        <span class="reveal-line"><span>Fast local plumbing</span></span>
        <span class="reveal-line"><span>across the bay,</span></span>
        <span class="reveal-line"><span>done <em class="kinetic">properly</em>.</span></span>
      </h1>

      <p data-hero class="hero__sub">
        Leaks, taps, toilets, hot water and general repairs — handled by a certified local plumber with
        upfront pricing and fast response.
      </p>

      <div data-hero class="hero__ctas">
        <CallButton size="lg" pulse />
        <a href="/services" class="btn-ghost" data-magnetic>
          See our services
          <Icon name="arrow" size={18} stroke="#B6FF3C" />
        </a>
      </div>

      <div data-hero class="hero__ticks">
        {['Certified', 'Bayside local', 'Fast response', 'Upfront pricing'].map((t, i) => (
          <>
            {i > 0 && <span class="hero__tick-sep"></span>}
            <span class="hero__tick"><span>✓</span> {t}</span>
          </>
        ))}
      </div>
    </div>

    <div class="hero__waterline-wrap">
      <div id="swp-waterline" class="hero__waterline"></div>
    </div>
  </section>

  <TrustBar />

  <!-- ===== WHAT CAN WE HELP WITH ===== -->
  <Section id="services">
    <SectionHeading eyebrow="What can we help with?" waterline max="640px">
      Tell us what's gone wrong — we'll sort it.
    </SectionHeading>
    <p data-reveal class="section-lead">
      From small leaks to urgent repairs, S&amp;W Plumbing handles general maintenance and residential
      plumbing across Birkdale and bayside Brisbane.
    </p>
    <div class="problems" data-anim-children>
      {
        problems.map((p) => (
          <a href={business.phoneHref} class="problem" data-tilt>
            <div class="problem__icon"><Icon name={p.icon} size={24} stroke="#B6FF3C" /></div>
            <div class="problem__body">
              <h3 class="problem__title">{p.title}</h3>
              <p class="problem__blurb">{p.blurb}</p>
            </div>
            <span class="problem__call">Call now <Icon name="arrow" size={14} stroke="#B6FF3C" /></span>
          </a>
        ))
      }
    </div>
    <div data-reveal class="problems__cta">
      <p>Not sure what the issue is? Call <strong>0432&nbsp;292&nbsp;371</strong> and we'll talk it through.</p>
      <CallButton size="md" pulse label="Call now" />
    </div>
  </Section>

  <!-- ===== CINEMATIC BAND ===== -->
  <section class="band" aria-label="Plumbing you can rely on">
    <div class="band__media" aria-hidden="true">
      <img src="/images/band-pipes.webp" alt="" width="1920" height="1040" loading="lazy" decoding="async" />
    </div>
    <div class="band__overlay" aria-hidden="true"></div>
    <div class="band__inner">
      <div data-reveal>
        <div class="eyebrow">Bayside Brisbane</div>
        <h2 class="band__title">Plumbing you can<br />actually <span class="lime">rely on.</span></h2>
        <p class="band__sub">
          Certified, local, and upfront — from a dripping tap to a burst main. We turn up when we say we
          will, quote it before we start, and leave the place tidy.
        </p>
        <div class="band__cta"><CallButton size="lg" pulse /></div>
      </div>
    </div>
  </section>

  <!-- ===== MEET YOUR PLUMBER ===== -->
  <Section class="meet">
    <div class="meet__grid">
      <div data-reveal class="meet__media">
        <div class="meet__frame">
          <picture>
            <source srcset="/images/about-founder.webp" type="image/webp" />
            <img
              src="/images/about-founder.png"
              alt="Your local S & W plumber working on a hot water unit in bayside Brisbane"
              width="720"
              height="900"
              loading="lazy"
              decoding="async"
            />
          </picture>
          <span class="meet__badge"><span class="badge__dot"></span> Birkdale, QLD</span>
        </div>
      </div>
      <div data-reveal class="meet__copy">
        <div class="eyebrow">Your local plumber</div>
        <h2 class="h2 meet__title">Meet your local bayside plumber.</h2>
        <p class="meet__lead">
          S&amp;W Plumbing provides certified maintenance and general plumbing across Birkdale and bayside
          Brisbane. You'll deal directly with a local plumber who values clear communication, upfront
          pricing and quality work done properly.
        </p>
        <ul class="meet__points">
          {
            [
              'Local to the bayside area',
              'Certified and insured',
              'Clear communication before work begins',
              'Respectful, tidy service',
              'Fast response where available',
            ].map((point) => (
              <li>
                <Icon name="check" size={16} stroke="#B6FF3C" /> {point}
              </li>
            ))
          }
        </ul>
        <div class="meet__cta"><CallButton size="md" pulse /></div>
      </div>
    </div>
  </Section>

  <!-- ===== REVIEWS ===== -->
  {
    reviews.length > 0 && (
      <Section tint class="reviews-section">
        <Reviews />
        <div data-reveal class="reviews-cta">
          <p>Need help with plumbing? Call <strong>0432&nbsp;292&nbsp;371</strong>.</p>
          <CallButton size="md" pulse label="Call now" />
        </div>
      </Section>
    )
  }

  <!-- ===== WHY S&W ===== -->
  <Section id="why" class="why" clip>
    <div data-parallax-bg class="why__glow"></div>
    <div class="why__content">
      <SectionHeading eyebrow="Why S&amp;W" max="640px">A new name, an old-school standard.</SectionHeading>
      <div class="grid-cards" data-anim-children>
        {
          why.map((w) => (
            <div class="why__card">
              <div class="why__icon"><Icon name={w.icon} size={28} stroke="#B6FF3C" /></div>
              <h3 class="why__title">{w.title}</h3>
              <p class="why__body">{w.body}</p>
            </div>
          ))
        }
      </div>
    </div>
  </Section>

  <!-- ===== JOB GALLERY (only renders once photos are added) ===== -->
  {
    jobs.length > 0 && (
      <Section>
        <JobGallery />
      </Section>
    )
  }

  <!-- ===== SERVICE AREA TEASER ===== -->
  <Section id="areas">
    <div class="areas">
      <div data-reveal class="areas__copy">
        <div class="eyebrow">Service area</div>
        <h2 class="h2 areas__title">Covering Birkdale and all of bayside Brisbane.</h2>
        <p class="areas__text">
          From the Redlands to Wynnum — Wellington Point, Cleveland, Capalaba, Victoria Point and
          everywhere between. If you're on the bay, we've got you.
        </p>
        <a href="/service-areas" class="btn-ghost" data-magnetic>
          Check your suburb <Icon name="arrow" size={17} stroke="#B6FF3C" />
        </a>
      </div>
      <div data-reveal><MapPanel variant="teaser" /></div>
    </div>
  </Section>

  <!-- ===== GUARANTEE ===== -->
  <Section border={false} class="guarantee-section">
    <div data-reveal class="guarantee">
      <div class="guarantee__glow"></div>
      <div class="guarantee__inner">
        <div class="eyebrow">Our promise</div>
        <h2 class="guarantee__title">We stand behind <span>our work.</span></h2>
        <p class="guarantee__text">
          If something isn't right with our work, we'll come back and make it right. Clear communication,
          upfront quotes and quality work done properly — that's the deal.
        </p>
        <div class="guarantee__chips">
          <span><Icon name="check" size={15} stroke="#B6FF3C" /> Workmanship backed</span>
          <span><Icon name="check" size={15} stroke="#B6FF3C" /> Upfront quotes</span>
          <span><Icon name="check" size={15} stroke="#B6FF3C" /> Clean, tidy work</span>
        </div>
      </div>
    </div>
  </Section>

  <CtaBand
    sub="Leaks, taps, toilets, hot water and general plumbing repairs — handled by a certified local plumber with clear pricing and fast response."
    points={['Licensed & insured', 'Fast bayside response', 'Upfront pricing', 'Clean, quality work']}
    note="Based near Birkdale · Servicing bayside Brisbane"
  >
    Need a plumber in Bayside Brisbane?<br /><span class="lime">Call S&amp;W Plumbing today.</span>
  </CtaBand>
</Layout>

<style>
  /* ---- HERO ---- */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    padding: 120px var(--pad-x) 64px;
  }
  @media (max-width: 860px) {
    .hero {
      padding-bottom: 120px;
    }
  }
  .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }
  .hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.5;
    transform: scale(1.05);
    animation: heroKenBurns 26s ease-in-out infinite alternate;
    will-change: transform;
  }
  @keyframes heroKenBurns {
    from {
      transform: scale(1.05) translate(0, 0);
    }
    to {
      transform: scale(1.17) translate(-2.5%, -2.5%);
    }
  }
  .hero__glow {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: radial-gradient(60% 50% at 28% 38%, rgba(127, 203, 0, 0.2), transparent 60%),
      radial-gradient(48% 44% at 76% 66%, rgba(182, 255, 60, 0.14), transparent 60%);
    animation: heroGlowDrift 20s ease-in-out infinite alternate;
  }
  @keyframes heroGlowDrift {
    to {
      transform: translate3d(4%, -3%, 0) scale(1.12);
    }
  }
  .hero__veil {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .hero__veil--top {
    background: radial-gradient(120% 90% at 50% 0%, rgba(10, 12, 14, 0) 28%, rgba(10, 12, 14, 0.9) 100%);
  }
  .hero__veil--bottom {
    background: linear-gradient(180deg, rgba(10, 12, 14, 0.6) 0%, rgba(10, 12, 14, 0.12) 38%, rgba(10, 12, 14, 0.88) 100%);
  }
  @media (prefers-reduced-motion: reduce) {
    .hero__media img,
    .hero__glow {
      animation: none;
    }
  }
  .hero__inner {
    position: relative;
    z-index: 2;
    max-width: 1080px;
    width: 100%;
    margin: 0 auto;
  }
  .hero__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.7rem, 8.2vw, 6.6rem);
    line-height: 0.95;
    letter-spacing: -0.025em;
    max-width: 14ch;
  }
  .hero__title em {
    font-style: normal;
    color: var(--lime);
  }
  .hero__sub {
    margin-top: 24px;
    font-size: clamp(1.02rem, 2.2vw, 1.3rem);
    color: var(--muted);
    max-width: 48ch;
    line-height: 1.55;
    font-weight: 500;
  }
  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 38px;
  }
  .hero__ticks {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px 22px;
    margin-top: 42px;
  }
  .hero__tick {
    font-size: 13.5px;
    color: var(--text);
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .hero__tick span {
    color: var(--lime);
  }
  .hero__tick-sep {
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--line-strong);
  }
  .hero__waterline-wrap {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 2px;
    z-index: 3;
    overflow: hidden;
  }
  .hero__waterline {
    height: 100%;
    width: 100%;
    transform: scaleX(0);
    transform-origin: left center;
    background: linear-gradient(90deg, rgba(182, 255, 60, 0) 0%, var(--lime) 50%, rgba(182, 255, 60, 0) 100%);
    box-shadow: 0 0 16px rgba(182, 255, 60, 0.8);
  }

  /* ---- CINEMATIC BAND ---- */
  .band {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    min-height: min(72vh, 640px);
    padding: clamp(80px, 12vw, 150px) var(--pad-x);
    border-top: 1px solid var(--ink-800);
  }
  .band__media {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }
  .band__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.05);
    animation: bandKenBurns 32s ease-in-out infinite alternate;
    will-change: transform;
  }
  @keyframes bandKenBurns {
    from {
      transform: scale(1.05) translate(0, 0);
    }
    to {
      transform: scale(1.18) translate(2.5%, 1.5%);
    }
  }
  .band__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
        90deg,
        rgba(10, 12, 14, 0.94) 0%,
        rgba(10, 12, 14, 0.78) 42%,
        rgba(10, 12, 14, 0.55) 100%
      ),
      radial-gradient(60% 80% at 18% 50%, rgba(127, 203, 0, 0.14), transparent 55%);
  }
  .band__inner {
    position: relative;
    z-index: 2;
    max-width: var(--container);
    margin: 0 auto;
    width: 100%;
  }
  .band__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.2rem, 6vw, 4.4rem);
    line-height: 1;
    letter-spacing: -0.025em;
    margin: 16px 0 0;
  }
  .band__title .lime {
    color: var(--lime);
  }
  .band__sub {
    margin-top: 20px;
    font-size: clamp(1.05rem, 2.2vw, 1.3rem);
    color: var(--muted);
    max-width: 44ch;
    line-height: 1.55;
  }
  .band__cta {
    margin-top: 34px;
  }
  @media (prefers-reduced-motion: reduce) {
    .band__media img {
      animation: none;
    }
  }

  /* ---- shared ---- */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 7px 14px;
    border: 1px solid var(--line);
    background: rgba(20, 24, 28, 0.6);
    backdrop-filter: blur(10px);
    border-radius: 999px;
    margin-bottom: 28px;
    font-size: 12.5px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted-2);
    font-weight: 600;
  }
  .badge__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--lime);
    box-shadow: 0 0 10px var(--lime);
  }
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    border: 1px solid var(--line-strong);
    background: rgba(20, 24, 28, 0.5);
    backdrop-filter: blur(10px);
    color: var(--text);
    font-weight: 600;
    font-size: clamp(1rem, 2vw, 1.1rem);
    padding: 16px 26px;
    border-radius: 999px;
    white-space: nowrap;
    transition: border-color 0.3s, background 0.3s, transform 0.3s;
    will-change: transform;
  }
  .btn-ghost:hover {
    border-color: var(--lime);
    background: var(--lime-08);
    transform: translateY(-3px);
  }
  .grid-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 18px;
  }

  /* ---- WHAT CAN WE HELP WITH (problems) ---- */
  .section-lead {
    margin: -34px 0 40px;
    max-width: 640px;
    font-size: 16px;
    color: var(--muted-2);
    line-height: 1.6;
  }
  .problems {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 14px;
  }
  @media (min-width: 1000px) {
    .problems {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .problem {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 14px;
    background: rgba(20, 24, 28, 0.6);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 24px;
    transition: transform 0.25s var(--ease-quint), border-color 0.4s, box-shadow 0.4s;
    transform-style: preserve-3d;
  }
  .problem:hover {
    border-color: rgba(182, 255, 60, 0.5);
    box-shadow: 0 24px 60px -24px rgba(182, 255, 60, 0.35);
  }
  .problem__icon {
    width: 46px;
    height: 46px;
    border-radius: 12px;
    background: var(--lime-10);
    border: 1px solid rgba(182, 255, 60, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--lime);
  }
  .problem__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.2rem;
    letter-spacing: -0.01em;
    margin-bottom: 6px;
  }
  .problem__blurb {
    font-size: 14px;
    color: var(--muted-2);
    line-height: 1.5;
  }
  .problem__call {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13.5px;
    font-weight: 700;
    color: var(--lime);
    margin-top: auto;
  }
  .problems__cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    margin-top: 26px;
    padding: 24px 28px;
    border: 1px solid rgba(182, 255, 60, 0.25);
    border-radius: var(--radius);
    background: linear-gradient(120deg, rgba(182, 255, 60, 0.08), rgba(20, 24, 28, 0.4));
  }
  .problems__cta p {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: var(--text);
    max-width: 52ch;
  }
  .problems__cta strong {
    color: var(--lime);
  }

  /* ---- WHY ---- */
  .why {
    position: relative;
    overflow: hidden;
  }
  .why__glow {
    position: absolute;
    top: -20%;
    right: -10%;
    width: 60%;
    height: 140%;
    z-index: 0;
    background: radial-gradient(circle, rgba(127, 203, 0, 0.1), rgba(10, 12, 14, 0) 65%);
    pointer-events: none;
  }
  .why__content {
    position: relative;
    z-index: 1;
  }
  .why__card {
    background: rgba(20, 24, 28, 0.5);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 34px;
  }
  .why__icon {
    width: 54px;
    height: 54px;
    border-radius: 14px;
    background: var(--lime-10);
    border: 1px solid rgba(182, 255, 60, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    color: var(--lime);
  }
  .why__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.5rem;
    margin-bottom: 12px;
    letter-spacing: -0.01em;
  }
  .why__body {
    font-size: 15px;
    color: var(--muted-2);
    line-height: 1.6;
  }

  /* ---- MEET YOUR PLUMBER ---- */
  .meet__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: clamp(36px, 5vw, 64px);
    align-items: center;
  }
  .meet__frame {
    position: relative;
    border: 1px solid rgba(182, 255, 60, 0.35);
    border-radius: 24px;
    padding: 10px;
    background: linear-gradient(160deg, rgba(182, 255, 60, 0.08), rgba(20, 24, 28, 0.4));
    box-shadow: 0 0 70px -24px rgba(182, 255, 60, 0.45);
    max-width: 440px;
  }
  .meet__frame picture {
    display: block;
    width: 100%;
    aspect-ratio: 4 / 5;
    border-radius: 18px;
    overflow: hidden;
  }
  .meet__frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .meet__badge {
    position: absolute;
    bottom: 22px;
    left: 22px;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 9px 15px;
    border-radius: 999px;
    background: rgba(10, 12, 14, 0.78);
    backdrop-filter: blur(10px);
    border: 1px solid var(--line);
    font-size: 13px;
    font-weight: 700;
  }
  .meet__title {
    margin: 16px 0 18px;
  }
  .meet__lead {
    font-size: 16px;
    color: var(--muted-2);
    line-height: 1.65;
    max-width: 50ch;
  }
  .meet__points {
    list-style: none;
    margin: 24px 0 30px;
    display: grid;
    gap: 12px;
  }
  .meet__points li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
  }
  .reviews-cta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 18px;
    margin-top: 36px;
  }
  .reviews-cta p {
    font-size: clamp(1rem, 2vw, 1.15rem);
