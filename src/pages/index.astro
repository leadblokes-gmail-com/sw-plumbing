---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import CallButton from '../components/CallButton.astro';
import Icon from '../components/Icon.astro';
import { business } from '../data/site';

const heroTrust = ['Licensed & insured', 'Same-day service', 'Upfront pricing', 'Local Brisbane plumber'];

const steps = [
  { n: '1', icon: 'quote', t: 'Tell us the problem', d: 'Call or send the form. We listen and book you in fast.' },
  { n: '2', icon: 'dollar', t: 'Get upfront pricing', d: 'A clear fixed price before any work starts — no surprises.' },
  { n: '3', icon: 'check', t: 'We fix it — pay when satisfied', d: 'Quality work, tested and tidied up before we leave.' },
];

const services = [
  { icon: 'hotwater', t: 'Hot Water', d: 'Repairs, replacements and new installs — electric and gas.' },
  { icon: 'drain', t: 'Blocked Drains', d: 'Sinks, showers, toilets and sewer lines cleared fast.' },
  { icon: 'leak', t: 'Leaking Pipes', d: 'Burst and leaking pipes located and repaired properly.' },
  { icon: 'tap', t: 'Taps & Toilets', d: 'Dripping taps, running toilets and cisterns sorted.' },
  { icon: 'gas', t: 'Gas Fitting', d: 'Gas appliances and lines connected safely and to code.' },
  { icon: 'bolt', t: 'Emergency Plumber', d: 'Fast local help when something goes wrong — 7 days.' },
];

// NOTE: business offers — confirm these are accurate/honoured before going live.
const offers = [
  { n: '01', t: 'Free Call Out', d: 'No call-out fee when we do the job — you only pay for the work.' },
  { n: '02', t: 'Thursday Special', d: 'Book a standard job on a Thursday and save on labour.' },
  { n: '03', t: 'Free Garden Tap', d: 'A complimentary garden tap replacement with any booked service.' },
];

const whyPoints = [
  { icon: 'pin', t: 'Servicing Brisbane & surrounding suburbs' },
  { icon: 'dollar', t: 'Fixed upfront pricing before work starts' },
  { icon: 'shield', t: 'Licensed and insured plumbers' },
  { icon: 'check', t: 'Lifetime labour warranty' },
  { icon: 'bolt', t: 'Same-day service available' },
  { icon: 'quote', t: 'Seniors discount available' },
  { icon: 'insured', t: 'Buy now, pay later options available' },
];

// SAMPLE reviews — placeholder layout only. Replace with real Google reviews
// before relying on them (fabricated testimonials breach the Australian Consumer Law).
const reviews = [
  { name: 'Jason R.', suburb: 'Wynnum', rating: 5, text: 'Turned up same day, gave a clear price upfront and fixed our hot water fast. Tidy and professional.' },
  { name: 'Priya M.', suburb: 'Cleveland', rating: 5, text: 'Blocked drain sorted in under an hour. Friendly, explained everything and no hidden costs.' },
  { name: 'Dave K.', suburb: 'Capalaba', rating: 5, text: 'Great local plumber. Quoted before starting, cleaned up after and the leak has not come back.' },
];
---
<Layout
  title="S&W Plumbing | Same-Day Plumber Brisbane & Bayside"
  description="Professional, reliable, local plumbing across Brisbane and Bayside. Same-day service for blocked drains, leaking taps, hot water, gas fitting and emergency repairs. Upfront pricing — call 0432 292 371."
>
  <!-- ===== 1. HERO ===== -->
  <section class="hero">
    <div class="hero__inner container">
      <div class="hero__copy">
        <div data-hero class="hero__badge"><span class="hero__badge-dot"></span> Same-day &amp; emergency plumbing</div>
        <h1 class="hero__title">Professional. Reliable. <span class="hl">Local plumbing.</span></h1>
        <p class="hero__sub">
          Same-day Brisbane plumbing for blocked drains, leaking taps, toilets, hot water, gas fitting
          and emergency repairs — done properly, priced upfront.
        </p>
        <div class="hero__ctas">
          <CallButton size="lg" label="Call Now" />
          <a href="#enquiry" class="btn-ghost-l">Get a Quote</a>
        </div>
        <ul class="hero__trust">
          {heroTrust.map((t) => <li><Icon name="check" size={15} stroke="#FF6A1A" /> {t}</li>)}
        </ul>
      </div>

      <div id="enquiry" class="qform">
        <div class="qform__head">
          <h2 class="qform__title">Tell us your problem</h2>
          <p class="qform__sub">Fast local response — we'll get right back to you.</p>
        </div>
        <ContactForm submitLabel="Get My Quote" compact />
      </div>
    </div>
  </section>

  <!-- ===== 2. EMERGENCY STRIP ===== -->
  <section class="emerg">
    <div class="container emerg__inner">
      <div class="emerg__text">
        <div class="emerg__k"><Icon name="bolt" size={26} stroke="#FFC531" /> 24/7 Emergency Plumbing Service</div>
        <p>7 days a week — fast local help when you need it most.</p>
      </div>
      <div class="emerg__ctas">
        <a href={business.phoneHref} class="btn-orange"><Icon name="phone" size={18} /> Call Now</a>
        <a href="/#enquiry" class="btn-outline-l">Book Online</a>
      </div>
    </div>
  </section>

  <!-- ===== 3. PROCESS ===== -->
  <section class="section proc">
    <div class="container">
      <div class="head head--center">
        <div class="eyebrow">How it works</div>
        <h2 class="h2">Our simple 3-step process</h2>
      </div>
      <div class="proc__grid" data-anim-children>
        {
          steps.map((s) => (
            <div class="proc__card">
              <span class="proc__num">{s.n}</span>
              <span class="proc__icon"><Icon name={s.icon} size={26} stroke="#FF6A1A" /></span>
              <h3 class="proc__t">{s.t}</h3>
              <p class="proc__d">{s.d}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== 4. SERVICES GRID ===== -->
  <section class="section svc" id="services" style="background:var(--bg-2)">
    <div class="container">
      <div class="head head--center">
        <div class="eyebrow">What we do</div>
        <h2 class="h2">Plumbing services across Brisbane &amp; Bayside</h2>
      </div>
      <div class="svc__grid" data-anim-children>
        {
          services.map((s) => (
            <div class="svc__card">
              <span class="svc__icon"><Icon name={s.icon} size={28} stroke="#FF6A1A" /></span>
              <h3 class="svc__t">{s.t}</h3>
              <p class="svc__d">{s.d}</p>
              <a href="/services" class="svc__link">Learn more <Icon name="arrow" size={13} stroke="#FF6A1A" /></a>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== 5. MID CTA ===== -->
  <section class="midcta">
    <div class="container midcta__inner">
      <h2 class="midcta__t">Need a plumber today?</h2>
      <div class="midcta__ctas">
        <a href={business.phoneHref} class="btn-orange btn--xl"><Icon name="phone" size={20} /> Call {business.phone}</a>
        <a href="/#enquiry" class="btn-outline-l btn--xl">Book Online</a>
      </div>
    </div>
  </section>

  <!-- ===== 6. DISCOUNTS / OFFERS ===== -->
  <section class="section offers" id="discounts">
    <div class="container">
      <div class="head head--center">
        <div class="eyebrow">Current offers</div>
        <h2 class="h2">Discounts &amp; specials</h2>
      </div>
      <div class="offers__grid" data-anim-children>
        {
          offers.map((o) => (
            <div class="offer">
              <span class="offer__badge">{o.n}</span>
              <h3 class="offer__t">{o.t}</h3>
              <p class="offer__d">{o.d}</p>
              <span class="offer__fine">Not redeemable with other offers.</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== 7. WHY CHOOSE US ===== -->
  <section class="section why" id="why" style="background:var(--bg-2)">
    <div class="container">
      <div class="head head--center">
        <div class="eyebrow">Why S&amp;W</div>
        <h2 class="h2">Why choose S&amp;W Plumbing</h2>
      </div>
      <div class="why__grid" data-anim-children>
        {
          whyPoints.map((w) => (
            <div class="why__card">
              <span class="why__icon"><Icon name={w.icon} size={22} stroke="#FF6A1A" /></span>
              <span class="why__t">{w.t}</span>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== 8. HELP / LOCAL TRUST ===== -->
  <section class="help">
    <div class="container help__inner">
      <div class="help__copy">
        <div class="eyebrow help__eyebrow">Local &amp; trusted</div>
        <h2 class="help__t">We're here to help</h2>
        <p class="help__d">
          S&amp;W Plumbing provides reliable, trustworthy residential and commercial plumbing across
          Brisbane, Bayside and the surrounding suburbs. From a dripping tap to a full emergency,
          you'll get a straight answer, an upfront price and the job done properly.
        </p>
        <div class="help__ctas">
          <a href={business.phoneHref} class="btn-orange"><Icon name="phone" size={18} /> Call Now</a>
          <a href="/#enquiry" class="btn-outline-l">Book Online</a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 9. REVIEWS ===== -->
  <section class="section reviews" id="reviews">
    <div class="container">
      <div class="head head--center">
        <div class="eyebrow">Reviews</div>
        <h2 class="h2">What local customers say</h2>
        <p class="reviews__note">Example layout — real Google reviews will be shown here as they come in.</p>
      </div>
      <div class="reviews__grid" data-anim-children>
        {
          reviews.map((r) => (
            <figure class="review">
              <div class="review__stars" aria-label={`${r.rating} out of 5`}>
                {Array.from({ length: r.rating }).map(() => <Icon name="star" size={17} stroke="#FFC531" />)}
              </div>
              <blockquote>{r.text}</blockquote>
              <figcaption>
                <span class="review__name">{r.name}</span>
                <span class="review__suburb">{r.suburb}</span>
              </figcaption>
            </figure>
          ))
        }
      </div>
      <div class="reviews__cta">
        <a href="/#enquiry" class="btn-navy">Write a review</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ---- buttons ---- */
  .btn-orange {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--orange);
    color: #fff;
    font-weight: 700;
    font-size: 1.05rem;
    padding: 15px 28px;
    border-radius: 999px;
    box-shadow: 0 10px 24px -12px rgba(255, 106, 26, 0.7);
    transition: background 0.25s, transform 0.25s;
  }
  .btn-orange:hover { background: var(--orange-dark); transform: translateY(-2px); }
  .btn-navy {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    background: var(--navy);
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    padding: 14px 26px;
    border-radius: 999px;
    transition: background 0.25s, transform 0.25s;
  }
  .btn-navy:hover { background: var(--navy-2); transform: translateY(-2px); }
  .btn-ghost-l {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    border: 1.5px solid rgba(255, 255, 255, 0.4);
    color: #fff;
    font-weight: 700;
    font-size: 1.05rem;
    padding: 14px 26px;
    border-radius: 999px;
    transition: border-color 0.25s, background 0.25s;
  }
  .btn-ghost-l:hover { border-color: #fff; background: rgba(255, 255, 255, 0.08); }
  .btn-outline-l {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    border: 1.5px solid rgba(255, 255, 255, 0.55);
    color: #fff;
    font-weight: 700;
    font-size: 1.05rem;
    padding: 14px 26px;
    border-radius: 999px;
    transition: border-color 0.25s, background 0.25s;
  }
  .btn-outline-l:hover { border-color: #fff; background: rgba(255, 255, 255, 0.1); }
  .btn--xl { font-size: 1.15rem; padding: 18px 34px; }

  .head { margin-bottom: 44px; }
  .head--center { text-align: center; max-width: 720px; margin-inline: auto; }
  .head .eyebrow { margin-bottom: 14px; }

  /* ---- 1. HERO ---- */
  .hero {
    color: #fff;
    padding: calc(clamp(96px, 13vh, 150px) + 30px) var(--pad-x) clamp(56px, 8vw, 96px);
    /* Photo layer sits under a navy overlay so the copy stays legible.
       Drop /public/images/hero-plumber.jpg to switch it on — until then the
       navy gradient below is the fallback and it looks identical to before. */
    background-color: var(--navy);
    background-image:
      linear-gradient(110deg, rgba(11, 27, 51, 0.96) 0%, rgba(11, 27, 51, 0.88) 42%, rgba(11, 27, 51, 0.6) 100%),
      radial-gradient(120% 90% at 88% 0%, rgba(255, 106, 26, 0.18), transparent 55%),
      url('/images/hero-plumber.jpg');
    background-size: cover, cover, cover;
    background-position: center, center, center right;
    background-repeat: no-repeat;
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(32px, 5vw, 64px);
    align-items: center;
  }
  @media (max-width: 920px) {
    .hero__inner { grid-template-columns: 1fr; gap: 36px; }
  }
  .hero__badge {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.16);
    color: #fff;
    font-size: 12.5px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 8px 15px;
    border-radius: 999px;
    margin-bottom: 22px;
  }
  .hero__badge-dot {
    width: 8px; height: 8px; border-radius: 50%; background: var(--orange);
  }
  .hero__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.5rem, 6vw, 4.4rem);
    line-height: 1.02;
    letter-spacing: -0.025em;
    color: #fff;
    max-width: 15ch;
  }
  .hero__title .hl { color: var(--orange); }
  .hero__sub {
    margin-top: 20px;
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    color: rgba(255, 255, 255, 0.82);
    max-width: 48ch;
    line-height: 1.6;
  }
  .hero__ctas { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 30px; }
  .hero__trust {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px 20px;
    margin-top: 30px;
    max-width: 460px;
  }
  .hero__trust li {
    display: flex; align-items: center; gap: 9px;
    font-size: 14.5px; font-weight: 600; color: #fff;
  }
  /* quote form card */
  .qform {
    background: #fff;
    border-radius: var(--radius-lg);
    padding: clamp(22px, 3vw, 32px);
    box-shadow: 0 30px 70px -30px rgba(0, 0, 0, 0.55);
    scroll-margin-top: 130px;
    border-top: 4px solid var(--orange);
  }
  .qform__head { margin-bottom: 18px; }
  .qform__title {
    font-family: var(--font-display); font-weight: 700; font-size: 1.55rem;
    color: var(--navy); letter-spacing: -0.01em;
  }
  .qform__sub { margin-top: 6px; font-size: 14px; color: var(--muted-2); }

  /* ---- 2. EMERGENCY STRIP ---- */
  .emerg {
    background: var(--orange);
    color: #fff;
    padding: clamp(22px, 3vw, 30px) var(--pad-x);
  }
  .emerg__inner {
    display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 18px;
  }
  .emerg__k {
    display: inline-flex; align-items: center; gap: 12px;
    font-family: var(--font-display); font-weight: 700;
    font-size: clamp(1.2rem, 3vw, 1.7rem); letter-spacing: -0.01em;
  }
  .emerg__text p { margin-top: 4px; font-size: 15px; color: rgba(255, 255, 255, 0.92); }
  .emerg__ctas { display: flex; flex-wrap: wrap; gap: 12px; }
  .emerg .btn-orange { background: #fff; color: var(--navy); box-shadow: none; }
  .emerg .btn-orange:hover { background: rgba(255, 255, 255, 0.9); }

  /* ---- 3. PROCESS ---- */
  .proc__grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px;
  }
  @media (max-width: 780px) { .proc__grid { grid-template-columns: 1fr; } }
  .proc__card {
    position: relative;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 34px 28px;
    box-shadow: 0 20px 40px -34px rgba(11, 27, 51, 0.4);
  }
  .proc__num {
    position: absolute; top: 22px; right: 26px;
    font-family: var(--font-display); font-weight: 700;
    font-size: 3rem; line-height: 1; color: var(--line-strong);
  }
  .proc__icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 56px; height: 56px; border-radius: 14px;
    background: var(--lime-10); color: var(--orange); margin-bottom: 20px;
  }
  .proc__t {
    font-family: var(--font-display); font-weight: 600; font-size: 1.3rem;
    color: var(--navy); letter-spacing: -0.01em; margin-bottom: 10px; max-width: 14ch;
  }
  .proc__d { font-size: 14.5px; color: var(--muted-2); line-height: 1.6; }

  /* ---- 4. SERVICES GRID ---- */
  .svc__grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;
  }
  @media (max-width: 900px) { .svc__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .svc__grid { grid-template-columns: 1fr; } }
  .svc__card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 30px 26px;
    transition: transform 0.3s var(--ease-quint), box-shadow 0.3s, border-color 0.3s;
  }
  .svc__card:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 106, 26, 0.4);
    box-shadow: 0 24px 46px -28px rgba(11, 27, 51, 0.45);
  }
  .svc__icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 58px; height: 58px; border-radius: 15px;
    background: var(--lime-10); color: var(--orange); margin-bottom: 20px;
  }
  .svc__t {
    font-family: var(--font-display); font-weight: 600; font-size: 1.4rem;
    color: var(--navy); letter-spacing: -0.01em; margin-bottom: 10px;
  }
  .svc__d { font-size: 14.5px; color: var(--muted-2); line-height: 1.6; margin-bottom: 16px; }
  .svc__link {
    display: inline-flex; align-items: center; gap: 7px;
    font-size: 14px; font-weight: 700; color: var(--orange-dark);
  }

  /* ---- 5. MID CTA ---- */
  .midcta {
    color: #fff;
    padding: clamp(48px, 7vw, 84px) var(--pad-x);
    /* Drop /public/images/emergency-night.jpg to switch on the night photo. */
    background-color: var(--navy);
    background-image:
      linear-gradient(90deg, rgba(11, 27, 51, 0.92) 0%, rgba(11, 27, 51, 0.7) 60%, rgba(11, 27, 51, 0.55) 100%),
      url('/images/emergency-night.jpg');
    background-size: cover, cover;
    background-position: center, center;
    background-repeat: no-repeat;
  }
  .midcta__inner {
    display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 24px;
  }
  .midcta__t {
    font-family: var(--font-display); font-weight: 600;
    font-size: clamp(1.9rem, 4.5vw, 3rem); letter-spacing: -0.02em; color: #fff;
  }
  .midcta__ctas { display: flex; flex-wrap: wrap; gap: 14px; }

  /* ---- 6. OFFERS ---- */
  .offers__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  @media (max-width: 820px) { .offers__grid { grid-template-columns: 1fr; } }
  .offer {
    position: relative;
    background: var(--navy);
    color: #fff;
    border-radius: var(--radius-lg);
    padding: 34px 30px;
    overflow: hidden;
  }
  .offer::before {
    content: ''; position: absolute; top: -30%; right: -10%;
    width: 55%; height: 120%;
    background: radial-gradient(circle, rgba(255, 106, 26, 0.22), transparent 68%);
  }
  .offer__badge {
    position: relative;
    display: inline-flex; align-items: center; justify-content: center;
    width: 48px; height: 48px; border-radius: 12px;
    background: var(--orange); color: #fff;
    font-family: var(--font-display); font-weight: 700; font-size: 1.15rem;
    margin-bottom: 18px;
  }
  .offer__t {
    position: relative;
    font-family: var(--font-display); font-weight: 600; font-size: 1.5rem;
    color: #fff; margin-bottom: 10px;
  }
  .offer__d { position: relative; font-size: 14.5px; color: rgba(255, 255, 255, 0.8); line-height: 1.6; margin-bottom: 16px; }
  .offer__fine { position: relative; font-size: 11.5px; color: rgba(255, 255, 255, 0.5); }

  /* ---- 7. WHY ---- */
  .why__grid {
    display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px;
    max-width: 900px; margin-inline: auto;
  }
  @media (max-width: 640px) { .why__grid { grid-template-columns: 1fr; } }
  .why__card {
    display: flex; align-items: center; gap: 14px;
    background: var(--card); border: 1px solid var(--line);
    border-radius: var(--radius); padding: 20px 22px;
  }
  .why__icon {
    display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0;
    width: 42px; height: 42px; border-radius: 11px;
    background: var(--lime-10); color: var(--orange);
  }
  .why__t { font-weight: 600; font-size: 15.5px; color: var(--navy); }

  /* ---- 8. HELP ---- */
  .help { padding: clamp(56px, 7vw, 96px) var(--pad-x); }
  .help__inner { max-width: 760px; margin-inline: auto; text-align: center; }
  .help__eyebrow { margin-bottom: 14px; }
  .help__t {
    font-family: var(--font-display); font-weight: 600;
    font-size: clamp(2rem, 4.6vw, 3rem); color: var(--navy); letter-spacing: -0.02em;
  }
  .help__d {
    margin: 18px auto 26px; max-width: 60ch;
    font-size: 16.5px; color: var(--muted); line-height: 1.7;
  }
  .help__ctas { display: flex; flex-wrap: wrap; gap: 14px; justify-content: center; }

  /* ---- 9. REVIEWS ---- */
  .reviews__note { margin-top: 12px; font-size: 13.5px; color: var(--faint); }
  .reviews__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  @media (max-width: 900px) { .reviews__grid { grid-template-columns: 1fr; } }
  .review {
    background: var(--card); border: 1px solid var(--line);
    border-radius: var(--radius); padding: 28px 26px;
    box-shadow: 0 20px 40px -34px rgba(11, 27, 51, 0.4);
  }
