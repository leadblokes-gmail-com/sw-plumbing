---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import CallButton from '../components/CallButton.astro';
import AssetImg from '../components/AssetImg.astro';
import MapPanel from '../components/MapPanel.astro';
import Icon from '../components/Icon.astro';
import { business } from '../data/site';

const heroTrust = ['Licensed QBCC Plumber', 'Fast Local Response', 'Upfront Pricing', 'Birkdale Local'];

// Premium image service cards — each card its own photo (no photo used more than twice site-wide).
const services = [
  { icon: 'drain', img: '/assets/blocked-drain.jpg', t: 'Blocked Drains', d: 'Blocked sinks, toilets, showers and stormwater lines cleared fast, before a small blockage turns into a big mess.' },
  { icon: 'tap', img: '/assets/leaking-tap.jpg', t: 'Leaking Taps & Toilets', d: 'Dripping taps and running toilets fixed properly, so you stop wasting water and money.' },
  { icon: 'hotwater', img: '/assets/hot-water-system.jpg', t: 'Hot Water Systems', d: 'No hot water? Repairs, replacements and new installs to get you back to hot showers fast.' },
  { icon: 'leak', img: '/assets/leaking-pipe.jpg', t: 'Burst Pipes', d: 'Burst or leaking pipe? We isolate it fast, stop the damage and repair it right the first time.' },
  { icon: 'maintenance', img: '/assets/hot-water.jpg', t: 'General Plumbing', d: 'Taps, toilets, pressure and fittings, plus all the everyday jobs done cleanly and charged fairly.' },
  { icon: 'shield', img: '/assets/hero-plumber-home.jpg', t: 'Maintenance Plumbing', d: 'Ongoing care for homes, rentals and real estate, catching the small stuff before it costs you big.' },
];

const trustCards = [
  { icon: 'shield', t: 'Licensed QBCC plumber' },
  { icon: 'dollar', t: 'Upfront pricing' },
  { icon: 'bolt', t: 'Payment plans available' },
  { icon: 'pin', t: 'Local Birkdale plumber' },
  { icon: 'check', t: 'Clean, respectful work' },
  { icon: 'check', t: 'No job too big or small' },
];

const suburbs = ['Birkdale', 'Wellington Point', 'Cleveland', 'Capalaba', 'Victoria Point', 'Wynnum', 'Manly', 'Thornlands', 'Alexandra Hills', 'Redlands'];

// "Plumbing without the runaround" — the trust promise shown until real Google
// reviews exist (no fabricated testimonials).
const trustExpect = [
  { icon: 'quote', t: 'Clear communication', d: 'Straight answers and honest options, so you always know what’s happening and why.' },
  { icon: 'check', t: 'Tidy workmanship', d: 'Boots off, drop sheets down, mess cleaned up. We leave your place better than we found it.' },
  { icon: 'dollar', t: 'Upfront pricing', d: 'You get a clear price before any work starts, so no nasty surprises on the invoice.' },
  { icon: 'pin', t: 'Local reliability', d: 'A Birkdale local who turns up when booked and stands behind the work, every single job.' },
];

---
<Layout
  title="S&W Plumbing | Local Plumber Birkdale, Bayside Brisbane & Redlands"
  description="Licensed local plumber in Birkdale servicing Bayside Brisbane and the Redlands: Wellington Point, Cleveland, Capalaba, Wynnum, Manly, Victoria Point. Blocked drains, leaking taps, hot water, burst pipes and maintenance. Upfront pricing. Call 0432 292 371."
>
  <!-- Signature scroll pipe: a green water-flow line that fills as you scroll,
       connecting the sections. Desktop-only + reduced-motion safe (see motion.ts). -->
  <div class="pipeflow" id="swp-pipe" aria-hidden="true">
    <svg class="pipe__svg" viewBox="0 0 24 1000" preserveAspectRatio="none">
      <line x1="12" y1="14" x2="12" y2="986" class="pipe__track" />
      <line x1="12" y1="14" x2="12" y2="986" class="pipe__flow" id="swp-pipe-flow" pathLength="1" />
    </svg>
    <span class="pipe__head" id="swp-pipe-head"></span>
  </div>

  <!-- ===== 1. HERO ===== -->
  <section class="hero">
    <div class="hero__inner container">
      <div class="hero__copy">
        <div class="hero__badge"><span class="hero__badge-dot"></span> Birkdale &amp; Bayside Brisbane Plumber</div>
        <h1 class="hero__title">Bayside plumbing done <span class="hl">fast, clean and properly.</span></h1>
        <p class="hero__sub">
          Blocked drain? Leaking tap? No hot water? S&amp;W Plumbing handles urgent repairs and everyday
          plumbing across Birkdale, Bayside Brisbane and the Redlands, with clear pricing before work starts.
        </p>
        <div class="hero__ctas">
          <CallButton size="lg" label="Call S&W Now" />
          <a href="/services" class="btn-ghost-l">View Services</a>
        </div>
        <ul class="hero__trust">
          {heroTrust.map((t) => <li><Icon name="check" size={15} stroke="#00A651" /> {t}</li>)}
        </ul>
      </div>

      <div class="hero__visual">
        <span class="hero__accent hero__accent--blue"></span>
        <span class="hero__accent hero__accent--orange"></span>
        <div class="hero__imgcard">
          <AssetImg src="/assets/hero-plumber-home.jpg" alt="S&W plumber greeting a homeowner at a Brisbane home" eager />
          <span class="hero__fbadge hero__fbadge--tl"><span class="dot"></span> Fast local response</span>
          <span class="hero__fbadge hero__fbadge--br">Licensed QBCC plumber · Birkdale local</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 2. BOOKING / QUOTE FORM (overlaps hero) ===== -->
  <div class="bookwrap">
    <div id="enquiry" class="bookcard container">
      <div class="bookcard__head">
        <span class="bookcard__eyebrow">Free quote</span>
        <h2 class="bookcard__title">Tell us what's going on</h2>
        <p class="bookcard__sub">Send the details and we'll get back to you as soon as possible. For urgent jobs, call now.</p>
      </div>
      <ContactForm submitLabel="Get My Quote" compact />
      <ul class="bookcard__trust">
        <li><Icon name="check" size={14} stroke="#00A651" /> Fast response</li>
        <li><Icon name="check" size={14} stroke="#00A651" /> Local plumber</li>
        <li><Icon name="check" size={14} stroke="#00A651" /> Upfront pricing</li>
      </ul>
    </div>
  </div>

  <!-- ===== 3. EMERGENCY STRIP ===== -->
  <section class="emerg">
    <div class="container emerg__inner">
      <div class="emerg__text">
        <span class="emerg__badge"><Icon name="bolt" size={24} stroke="#19C463" /></span>
        <div>
          <div class="emerg__k">After-Hours Emergency Help</div>
          <p class="emerg__sub">Mon to Fri 7am to 5pm · Sat by appointment · limited after-hours. Call and we'll sort a time.</p>
        </div>
      </div>
      <div class="emerg__ctas">
        <a href={business.phoneHref} class="btn-orange"><Icon name="phone" size={18} /> Call Now</a>
        <a href="/#enquiry" class="btn-outline-l">Get a Quote</a>
      </div>
    </div>
  </section>

  <!-- ===== 4. SERVICES GRID (image-led) ===== -->
  <section class="section svc" id="services" style="background:var(--bg-2)">
    <div class="container">
      <div class="head head--center">
        <div class="eyebrow">What we do</div>
        <h2 class="h2">Plumbing services across Brisbane &amp; Bayside</h2>
        <p class="head__sub">From urgent repairs to everyday maintenance, one local team for the lot, priced upfront.</p>
      </div>
      <div class="svc__grid" data-anim-children>
        {
          services.map((s) => (
            <a href="/services" class="svc__card">
              <div class="svc__media">
                <AssetImg src={s.img} alt={`${s.t} by S&W Plumbing, Bayside Brisbane`} />
                <span class="svc__badge"><Icon name={s.icon} size={20} stroke="#FFFFFF" /></span>
              </div>
              <div class="svc__body">
                <h3 class="svc__t">{s.t}</h3>
                <p class="svc__d">{s.d}</p>
                <span class="svc__link">Learn more <Icon name="arrow" size={13} stroke="#00A651" /></span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== 5. WHY CHOOSE (team image + trust) ===== -->
  <section class="section why" id="why" style="background:var(--blue-soft)">
    <div class="container why__inner">
      <div class="why__media">
        <AssetImg src="/assets/hot-water-system.jpg" alt="Hot water system installed by S&W Plumbing in bayside Brisbane" class="why__img" />
      </div>
      <div class="why__copy">
        <div class="eyebrow">Why S&amp;W</div>
        <h2 class="why__title">A real local team you can trust with your home.</h2>
        <p class="why__lead">
          You deal directly with local Brisbane plumbers who give clear advice, upfront pricing and work done
          properly, every job.
        </p>
        <div class="why__cards" data-anim-children>
          {
            trustCards.map((c) => (
              <div class="why__card">
                <span class="why__icon"><Icon name={c.icon} size={18} stroke="#00A651" /></span>
                <span class="why__t">{c.t}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 6. EMERGENCY CTA (dark premium band) ===== -->
  <section class="ecta">
    <span class="ecta__overlay"></span>
    <div class="container ecta__inner">
      <h2 class="ecta__t">Need a plumber today?</h2>
      <p class="ecta__d">For burst pipes, blocked toilets, major leaks or no hot water, calling is the fastest way to get help.</p>
      <div class="ecta__ctas">
        <CallButton size="xl" label="Call S&W Now" pulse />
        <a href="/#enquiry" class="btn-outline-l btn--xl">Get Quote</a>
      </div>
      <p class="ecta__note">Available for urgent plumbing across Birkdale, Bayside Brisbane and the Redlands.</p>
    </div>
  </section>

  <!-- ===== 7. LOCAL / BRISBANE (van image split) ===== -->
  <section class="section local">
    <div class="container local__inner">
      <div class="local__copy">
        <div class="eyebrow">Areas we service</div>
        <h2 class="h2 local__title">Your local plumber across Birkdale, Bayside Brisbane &amp; the Redlands</h2>
        <p class="local__d">
          Based in Birkdale, S&amp;W Plumbing provides reliable plumbing across the bay and Redlands:
          Wellington Point, Cleveland, Capalaba, Wynnum, Manly, Victoria Point, Thornlands and nearby.
          A local who knows the area and turns up when booked.
        </p>
        <div class="local__chips">
          {suburbs.map((s) => <span class="chip">{s}</span>)}
        </div>
        <div class="local__ctas">
          <a href={business.phoneHref} class="btn-orange"><Icon name="phone" size={18} /> Call Now</a>
          <a href="/service-areas" class="btn-ghost-l">Check your suburb</a>
        </div>
      </div>
      <div class="local__media">
        <MapPanel variant="teaser" />
      </div>
    </div>
  </section>

  <!-- ===== 9. WHAT YOU CAN EXPECT (trust, not fake reviews) ===== -->
  <section class="section reviews" id="reviews" style="background:var(--bg-2)">
    <div class="container">
      <div class="head head--center">
        <div class="eyebrow">Why homeowners call us back</div>
        <h2 class="h2">Plumbing without the runaround.</h2>
        <p class="head__sub">No pushy upsells and no runaround, just honest local plumbing done properly, with the price agreed before we start.</p>
      </div>
      <div class="expect__grid" data-anim-children>
        {
          trustExpect.map((c) => (
            <div class="expect">
              <span class="expect__icon"><Icon name={c.icon} size={18} stroke="#00A651" /></span>
              <div>
                <h3 class="expect__t">{c.t}</h3>
                <p class="expect__d">{c.d}</p>
              </div>
            </div>
          ))
        }
      </div>
      <p class="reviews__note"><Icon name="quote" size={15} stroke="#00A651" /> Customer reviews coming soon. Until then, speak directly with S&amp;W Plumbing and get clear advice before booking.</p>
    </div>
  </section>
</Layout>

<style>
  /* ---- signature scroll pipe ---- */
  .pipeflow {
    position: fixed;
    left: clamp(14px, 2.4vw, 34px);
    top: 0;
    width: 22px;
    height: 100vh;
    z-index: 40;
    pointer-events: none;
    display: none;
  }
  /* Only show where there's whitespace beside the 1200px container. */
  @media (min-width: 1280px) {
    .pipeflow { display: block; }
  }
  .pipe__svg { width: 100%; height: 100%; overflow: visible; }
  .pipe__track {
    stroke: rgba(0, 166, 81, 0.14);
    stroke-width: 3; stroke-linecap: round;
    vector-effect: non-scaling-stroke;
  }
  .pipe__flow {
    stroke: var(--green-bright);
    stroke-width: 3; stroke-linecap: round;
    vector-effect: non-scaling-stroke;
    stroke-dasharray: 1;
    stroke-dashoffset: 1; /* filled by scroll via motion.ts */
    filter: drop-shadow(0 0 5px rgba(25, 196, 99, 0.7));
  }
  .pipe__head {
    position: absolute; left: 50%; top: 0;
    transform: translate(-50%, -50%);
    width: 12px; height: 12px; border-radius: 50%;
    background: var(--green-bright);
    box-shadow: 0 0 12px 3px rgba(25, 196, 99, 0.75), 0 0 26px 7px rgba(25, 196, 99, 0.32);
  }
  @media (prefers-reduced-motion: reduce) {
    .pipe__head { display: none; }
  }

  /* ---- buttons ---- */
  .btn-orange {
    display: inline-flex; align-items: center; gap: 10px;
    background: var(--orange); color: #fff; font-weight: 700; font-size: 1.05rem;
    padding: 15px 28px; border-radius: 999px;
    box-shadow: 0 10px 24px -12px rgba(0, 166, 81, 0.6);
    transition: background 0.25s, transform 0.25s;
  }
  .btn-orange:hover { background: var(--orange-dark); transform: translateY(-2px); }
  .btn-ghost-l {
    display: inline-flex; align-items: center; gap: 9px;
    border: 1.5px solid var(--blue); color: var(--blue); background: #fff;
    font-weight: 700; font-size: 1.05rem; padding: 14px 26px; border-radius: 999px;
    transition: border-color 0.25s, background 0.25s, color 0.25s;
  }
  .btn-ghost-l:hover { background: var(--blue); color: #fff; }
  .btn-outline-l {
    display: inline-flex; align-items: center; gap: 9px;
    border: 1.5px solid rgba(255, 255, 255, 0.55); color: #fff;
    font-weight: 700; font-size: 1.05rem; padding: 14px 26px; border-radius: 999px;
    transition: border-color 0.25s, background 0.25s;
  }
  .btn-outline-l:hover { border-color: #fff; background: rgba(255, 255, 255, 0.1); }
  .btn--xl { font-size: 1.15rem; padding: 18px 34px; }

  .head { margin-bottom: 40px; }
  .head--center { text-align: center; max-width: 720px; margin-inline: auto; }
  .head .eyebrow { margin-bottom: 14px; }
  .head__sub { margin-top: 14px; font-size: 16px; color: var(--muted-2); line-height: 1.6; max-width: 54ch; margin-inline: auto; }

  /* ---- 1. HERO ---- */
  .hero {
    position: relative;
    overflow: hidden;
    color: var(--ink);
    padding: calc(clamp(100px, 13vh, 160px) + 24px) var(--pad-x) clamp(96px, 12vw, 160px);
    background:
      radial-gradient(78% 62% at 88% -5%, rgba(0, 166, 81, 0.12), transparent 60%),
      linear-gradient(135deg, #f6faf8 0%, #ffffff 48%, #eaf8f0 100%);
  }
  /* subtle blueprint grid, faded — plumbing "plans" texture */
  .hero::before {
    content: ''; position: absolute; inset: 0; z-index: 0; pointer-events: none;
    background-image:
      linear-gradient(rgba(16, 20, 18, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(16, 20, 18, 0.04) 1px, transparent 1px);
    background-size: 46px 46px;
    -webkit-mask-image: radial-gradient(72% 82% at 28% 26%, #000 0%, transparent 74%);
    mask-image: radial-gradient(72% 82% at 28% 26%, #000 0%, transparent 74%);
  }
  .hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.02fr 0.98fr;
    gap: clamp(32px, 5vw, 64px);
    align-items: center;
  }
  @media (max-width: 940px) {
    .hero__inner { grid-template-columns: 1fr; gap: 32px; }
  }
  .hero__badge {
    display: inline-flex; align-items: center; gap: 9px;
    background: #fff; border: 1px solid var(--blue-border); color: var(--blue);
    font-size: 12.5px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
    padding: 8px 15px; border-radius: 999px; margin-bottom: 22px;
  }
  .hero__badge-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--orange); }
  .hero__title {
    font-family: var(--font-display); font-weight: 600;
    font-size: clamp(2.8rem, 6.6vw, 5.1rem); line-height: 0.98; letter-spacing: -0.035em;
    color: var(--ink); max-width: 16ch;
  }
  .hero__title .hl {
    color: var(--green);
    text-shadow: 0 6px 30px rgba(0, 166, 81, 0.28);
  }
  .hero__sub {
    margin-top: 22px; font-size: clamp(1.08rem, 2vw, 1.3rem); color: var(--muted);
    max-width: 50ch; line-height: 1.62;
  }
  .hero__ctas { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 34px; }
  .hero__trust {
    list-style: none; display: flex; flex-wrap: wrap; gap: 10px;
    margin-top: 34px; max-width: 540px;
  }
  .hero__trust li {
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(255, 255, 255, 0.8); border: 1px solid var(--line);
    border-radius: 999px; padding: 9px 15px;
    font-size: 13.5px; font-weight: 700; color: var(--ink);
    box-shadow: var(--shadow-sm); backdrop-filter: blur(4px);
  }
  /* hero visual */
  .hero__visual { position: relative; }
  .hero__accent {
    position: absolute; border-radius: 40% 60% 55% 45%; filter: blur(6px); z-index: 0;
  }
  .hero__accent--blue {
    width: 62%; height: 78%; right: -6%; top: -8%;
    background: radial-gradient(circle at 50% 50%, rgba(0, 166, 81, 0.22), transparent 70%);
  }
  .hero__accent--orange {
    width: 38%; height: 40%; left: -4%; bottom: -6%;
    background: radial-gradient(circle at 50% 50%, rgba(0, 166, 81, 0.2), transparent 70%);
  }
  .hero__imgcard {
    position: relative; z-index: 1;
    aspect-ratio: 5 / 4;
    border-radius: 26px; overflow: hidden;
    box-shadow: 0 40px 80px -40px rgba(5, 7, 8, 0.5);
    border: 5px solid #fff;
  }
  @media (max-width: 940px) { .hero__imgcard { aspect-ratio: 16 / 11; } }
  .hero__fbadge {
    position: absolute; z-index: 2;
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(255, 255, 255, 0.95); color: var(--ink);
    font-size: 12.5px; font-weight: 700; padding: 9px 14px; border-radius: 999px;
    box-shadow: 0 12px 24px -14px rgba(5, 7, 8, 0.5);
  }
  .hero__fbadge .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--orange); }
  .hero__fbadge--tl { top: 16px; left: 16px; }
  .hero__fbadge--br { bottom: 16px; right: 16px; color: var(--blue); }

  /* ---- 2. BOOKING CARD ---- */
  .bookwrap { position: relative; z-index: 5; padding: 0 var(--pad-x); margin-top: clamp(-70px, -6vw, -48px); }
  .bookcard {
    background: #fff; border: 1px solid var(--line); border-top: 4px solid var(--blue);
    border-radius: 24px; padding: clamp(24px, 3vw, 36px); max-width: 900px;
    box-shadow: 0 40px 80px -44px rgba(5, 7, 8, 0.4);
    scroll-margin-top: 120px;
  }
  .bookcard__head { margin-bottom: 20px; }
  .bookcard__eyebrow {
    display: inline-block; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    font-weight: 800; color: var(--green-dark); background: var(--green-light);
    padding: 5px 11px; border-radius: 999px; margin-bottom: 12px;
  }
  .bookcard__title {
    font-family: var(--font-display); font-weight: 700; font-size: 1.7rem; color: var(--ink); letter-spacing: -0.01em; line-height: 1.1;
  }
  .bookcard__sub { margin-top: 8px; font-size: 14.5px; color: var(--muted-2); line-height: 1.5; max-width: 46ch; }
  .bookcard__trust {
    list-style: none; display: flex; flex-wrap: wrap; gap: 10px 24px;
    margin-top: 18px; padding-top: 18px; border-top: 1px solid var(--line);
  }
  .bookcard__trust li { display: inline-flex; align-items: center; gap: 7px; font-size: 13.5px; font-weight: 600; color: var(--muted); }

  /* ---- 3. EMERGENCY STRIP ---- */
  .emerg {
    background: linear-gradient(100deg, var(--black) 0%, var(--charcoal) 58%, #0e2c1e 100%);
    color: #fff;
    padding: clamp(26px, 3.4vw, 38px) var(--pad-x);
    border-top: 2px solid var(--green);
  }
  .emerg__inner { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 20px; }
  .emerg__text { display: flex; align-items: center; gap: 16px; }
  .emerg__badge {
    display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0;
    width: 52px; height: 52px; border-radius: 14px;
    background: rgba(25, 196, 99, 0.14); border: 1px solid rgba(25, 196, 99, 0.35); color: var(--green-bright);
  }
  .emerg__k {
    font-family: var(--font-body); font-weight: 800;
    font-size: clamp(1.2rem, 2.6vw, 1.6rem); letter-spacing: -0.01em; line-height: 1.2;
  }
  .emerg__sub { margin-top: 3px; font-size: 14.5px; color: rgba(255, 255, 255, 0.7); }
  .emerg__ctas { display: flex; flex-wrap: wrap; gap: 12px; }

  /* ---- 4. SERVICES GRID (image-led premium cards) ---- */
  .svc__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  @media (max-width: 900px) { .svc__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .svc__grid { grid-template-columns: 1fr; } }
  .svc__card {
    display: flex; flex-direction: column;
    background: var(--card); border: 1px solid var(--line);
    border-radius: var(--radius); overflow: hidden;
    box-shadow: var(--shadow-md);
    transition: transform 0.35s var(--ease-quint), box-shadow 0.35s, border-color 0.35s;
  }
  .svc__card:hover {
    transform: translateY(-6px); border-color: rgba(0, 166, 81, 0.55);
    box-shadow: 0 40px 70px -34px rgba(11, 40, 26, 0.6);
  }
  .svc__media { position: relative; aspect-ratio: 16 / 10; overflow: hidden; }
  .svc__media :global(img) { transition: transform 0.7s var(--ease-quint); }
  .svc__card:hover .svc__media :global(img) { transform: scale(1.06); }
  .svc__media::after {
    content: ''; position: absolute; inset: 0; pointer-events: none;
    background: linear-gradient(to top, rgba(5, 7, 8, 0.5) 0%, rgba(5, 7, 8, 0.1) 34%, transparent 58%);
  }
  .svc__badge {
    position: absolute; top: 14px; left: 14px; z-index: 2;
    display: inline-flex; align-items: center; justify-content: center;
    width: 46px; height: 46px; border-radius: 12px; background: var(--green); color: #fff;
    box-shadow: 0 8px 18px -8px rgba(0, 166, 81, 0.85);
    transition: transform 0.35s var(--ease-quint);
  }
  .svc__card:hover .svc__badge { transform: translateY(-2px) scale(1.06); }
  .svc__body { position: relative; display: flex; flex-direction: column; flex: 1; padding: 24px 24px 26px; }
