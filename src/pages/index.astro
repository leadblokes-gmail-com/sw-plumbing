---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Accordion from '../components/Accordion.astro';
import ContactForm from '../components/ContactForm.astro';
import CallButton from '../components/CallButton.astro';
import CtaBand from '../components/CtaBand.astro';
import Icon from '../components/Icon.astro';
import { business, faqs, suburbs } from '../data/site';

const heroTrust = ['Clear pricing before work starts', 'Clean, tidy work', 'Local response where available'];

const numberedServices = [
  { n: '01', title: 'General plumbing', desc: 'Everyday repairs and the odd jobs that keep a property running.' },
  { n: '02', title: 'Blocked drains & toilets', desc: 'Sinks, showers, toilets and sewer lines cleared and flowing.' },
  { n: '03', title: 'Burst pipes & leaks', desc: 'Leaks isolated and repaired to stop the damage and the water bill.' },
  { n: '04', title: 'Hot water systems', desc: 'Repairs and installs — back to hot showers without the wait.' },
  { n: '05', title: 'Tap, toilet & cistern repairs', desc: 'Dripping taps, running toilets and worn cisterns sorted.' },
  { n: '06', title: 'Gas fitting', desc: 'Gas appliances and fittings connected safely and to code.' },
  { n: '07', title: 'Roof & gutter leaks', desc: 'Roof leak investigation, gutter and stormwater repairs.' },
  { n: '08', title: 'Renovation plumbing', desc: 'Rough-in to fit-off for bathroom and laundry renos.' },
];

const whyCards = [
  { t: 'Clear pricing before work starts', d: 'You know the number before we begin — no surprises on the invoice.' },
  { t: 'Clean, respectful work', d: 'We treat your place with care and leave it tidy when we go.' },
  { t: 'Local Bayside service', d: 'Based near Birkdale, working across the bay and the Redlands.' },
  { t: 'Work explained clearly', d: "We tell you what's going on and what the best next step is." },
];

const steps = [
  { n: '1', t: 'Get in touch', d: "Call or send the form and tell us what's going on." },
  { n: '2', t: 'We assess the job', d: 'We inspect the issue and explain the best next step.' },
  { n: '3', t: 'Quote before work starts', d: 'You know the price before we begin.' },
  { n: '4', t: 'Sorted properly', d: 'We complete the work, test it and leave the area tidy.' },
];

const proof = [
  'Local to Birkdale',
  'Clear pricing',
  'Clean work',
  'Business details available on request',
];

const faqSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];
---
<Layout
  title="S&W Plumbing | Plumber Birkdale & Bayside Brisbane"
  description="Local plumber servicing Birkdale, Wynnum, Cleveland, Wellington Point and Bayside Brisbane. Maintenance and general plumbing — leaks, taps, toilets, hot water, burst pipes and gas fitting. Clear pricing before work starts — call 0432 292 371."
  schema={faqSchema}
>
  <!-- ===== 1. HERO ===== -->
  <section class="hero">
    <div class="hero__inner container">
      <div class="hero__copy">
        <div data-hero class="eyebrow hero__label">Birkdale plumber</div>
        <h1 class="hero__title hero-mask">
          <span class="reveal-line"><span>Quality plumbing,</span></span>
          <span class="reveal-line"><span>done <em class="kinetic">properly</em>.</span></span>
        </h1>
        <p data-hero class="hero__sub">
          Maintenance and general plumbing for homes, rentals and small businesses across Birkdale,
          Bayside Brisbane and the Redlands.
        </p>
        <div data-hero class="hero__ctas">
          <a href="#enquiry" class="btn-primary">Book a quote</a>
          <CallButton size="md" />
        </div>
        <ul data-hero class="hero__trust">
          {heroTrust.map((t) => <li><Icon name="check" size={15} stroke="#0F2F28" /> {t}</li>)}
        </ul>
      </div>

      <div id="enquiry" data-hero class="hero__form">
        <h2 class="hero__form-title">Tell us what you need</h2>
        <p class="hero__form-sub">Send the details and we'll be in touch, or call and talk it through.</p>
        <ContactForm submitLabel="Send enquiry" compact />
      </div>
    </div>
  </section>

  <!-- ===== 2. SERVICES ===== -->
  <Section id="services">
    <div class="services__head">
      <SectionHeading eyebrow="Services" max="640px" class="services__heading">
        Everything your property needs, under one local name.
      </SectionHeading>
      <p data-reveal class="services__sub">
        General plumbing, repairs and maintenance for Bayside homes, rentals and small businesses.
      </p>
    </div>
    <div class="numgrid" data-anim-children>
      {
        numberedServices.map((s) => (
          <a href="/services" class="numcard">
            <span class="numcard__n">{s.n}</span>
            <h3 class="numcard__title">{s.title}</h3>
            <p class="numcard__desc">{s.desc}</p>
            <span class="numcard__more">Learn more <Icon name="arrow" size={13} stroke="#B99A52" /></span>
          </a>
        ))
      }
    </div>
  </Section>

  <!-- ===== 3. WHY CHOOSE S&W (dark green) ===== -->
  <section class="why">
    <div class="container why__inner">
      <div data-reveal class="why__copy">
        <div class="eyebrow why__eyebrow">Why S&amp;W</div>
        <h2 class="why__title">A local plumber you can actually get straight answers from.</h2>
        <p class="why__lead">
          When you call S&amp;W Plumbing, you deal directly with a local plumber — no call centre, no
          vague runaround, just clear advice and work done properly.
        </p>
        <CallButton size="md" />
      </div>
      <div class="why__cards" data-anim-children>
        {
          whyCards.map((c) => (
            <div class="why__card">
              <Icon name="check" size={18} stroke="#B99A52" />
              <div>
                <h3 class="why__card-title">{c.t}</h3>
                <p class="why__card-desc">{c.d}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== 4. PROCESS ===== -->
  <Section>
    <SectionHeading eyebrow="How it works" max="640px">Straightforward service, start to finish.</SectionHeading>
    <div class="steps" data-anim-children>
      {
        steps.map((s) => (
          <div class="step">
            <span class="step__n">{s.n}</span>
            <h3 class="step__title">{s.t}</h3>
            <p class="step__desc">{s.d}</p>
          </div>
        ))
      }
    </div>
  </Section>

  <!-- ===== 5. ABOUT / LOCAL PLUMBER ===== -->
  <Section tint>
    <div class="about">
      <div data-reveal class="about__media">
        <div class="about__placeholder">
          <Icon name="pin" size={26} stroke="#0F2F28" />
          <span>Owner photo to be added</span>
          <small>A real photo of your local plumber goes here.</small>
        </div>
      </div>
      <div data-reveal class="about__copy">
        <div class="eyebrow">Your local plumber</div>
        <h2 class="h2 about__title">Built on old-school standards.</h2>
        <p class="about__lead">
          S&amp;W Plumbing is based near Birkdale and services Bayside Brisbane and the Redlands. The
          business is built on simple standards: turn up, explain the job clearly, price it before
          starting and leave the place tidy.
        </p>
        <div class="about__ctas">
          <a href="/about" class="btn-outline">Meet S&amp;W</a>
          <CallButton size="md" />
        </div>
      </div>
    </div>
  </Section>

  <!-- ===== 6. PROOF OVER PROMISES ===== -->
  <Section>
    <SectionHeading eyebrow="Proof" max="640px">Proof over promises.</SectionHeading>
    <p data-reveal class="lead">
      Real reviews and project photos can be added here as they come in — no fake quotes, no made-up
      stars.
    </p>
    <div class="proof" data-anim-children>
      {
        proof.map((p) => (
          <div class="proof__card">
            <Icon name="check" size={18} stroke="#0F2F28" />
            <h3 class="proof__title">{p}</h3>
          </div>
        ))
      }
    </div>
  </Section>

  <!-- ===== 7. SERVICE AREAS ===== -->
  <Section tint id="areas">
    <SectionHeading eyebrow="Service areas" max="720px">
      Servicing Birkdale, Bayside Brisbane and the Redlands.
    </SectionHeading>
    <div class="chips" data-reveal>
      {
        suburbs.map((s) => (
          <span class:list={['chip', { 'chip--hq': s.hq }]}>
            {s.hq && <span class="chip__dot" />}
            {s.name}
          </span>
        ))
      }
    </div>
    <a href="/service-areas" class="btn-outline chips__cta" data-reveal>
      Check your suburb <Icon name="arrow" size={16} stroke="#0F2F28" />
    </a>
  </Section>

  <!-- ===== 8. FAQ ===== -->
  <Section>
    <div class="faq">
      <SectionHeading eyebrow="Good to know" max="820px">Common questions.</SectionHeading>
      <Accordion items={faqs} />
    </div>
  </Section>

  <!-- ===== 9. FINAL CTA ===== -->
  <CtaBand sub="For clear advice and practical plumbing support across Bayside Brisbane, call S&W Plumbing today.">
    Let's get your plumbing <span class="lime">sorted.</span>
  </CtaBand>
</Layout>

<style>
  /* ---- shared buttons ---- */
  .btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    background: var(--brass);
    color: var(--forest-2);
    font-weight: 700;
    font-size: clamp(1rem, 2vw, 1.12rem);
    padding: 15px 28px;
    border-radius: 999px;
    transition: transform 0.3s var(--ease-quint), background 0.3s;
  }
  .btn-primary:hover {
    transform: translateY(-2px);
    background: #c9ac63;
  }
  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    border: 1px solid var(--line-strong);
    color: var(--forest);
    background: var(--card);
    font-weight: 600;
    font-size: 1rem;
    padding: 14px 24px;
    border-radius: 999px;
    transition: border-color 0.3s, background 0.3s;
  }
  .btn-outline:hover {
    border-color: var(--forest);
  }
  .lead {
    margin: -26px 0 40px;
    max-width: 60ch;
    font-size: 16px;
    color: var(--muted-2);
    line-height: 1.65;
  }

  /* ---- 1. HERO ---- */
  .hero {
    padding: calc(clamp(96px, 12vh, 140px) + 40px) var(--pad-x) clamp(48px, 7vw, 88px);
    background: linear-gradient(180deg, var(--cream) 0%, var(--cream-2) 100%);
  }
  .hero__inner {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: clamp(32px, 5vw, 64px);
    align-items: center;
  }
  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }
  .hero__label {
    margin-bottom: 18px;
  }
  .hero__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.6rem, 6vw, 4.6rem);
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--forest);
  }
  .hero__title em {
    font-style: normal;
    color: var(--brass-dark);
  }
  .hero__sub {
    margin-top: 20px;
    font-size: clamp(1.02rem, 2vw, 1.2rem);
    color: var(--muted);
    max-width: 46ch;
    line-height: 1.6;
  }
  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 30px;
  }
  .hero__trust {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-top: 28px;
  }
  .hero__trust li {
    display: flex;
    align-items: center;
    gap: 9px;
    font-size: 14.5px;
    font-weight: 600;
    color: var(--text);
  }
  .hero__form {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    padding: clamp(24px, 3vw, 34px);
    box-shadow: 0 24px 60px -40px rgba(15, 47, 40, 0.4);
    scroll-margin-top: 120px;
  }
  .hero__form-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.5rem;
    letter-spacing: -0.01em;
    color: var(--forest);
  }
  .hero__form-sub {
    margin: 8px 0 20px;
    font-size: 14px;
    color: var(--muted-2);
    line-height: 1.5;
  }

  /* ---- 2. SERVICES ---- */
  .services__head {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 44px;
  }
  .services__head :global(.services__heading) {
    margin-bottom: 0;
  }
  .services__sub {
    font-size: 15px;
    color: var(--muted-2);
    max-width: 40ch;
    line-height: 1.6;
  }
  .numgrid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }
  @media (max-width: 1000px) {
    .numgrid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 560px) {
    .numgrid { grid-template-columns: 1fr; }
  }
  .numcard {
    display: flex;
    flex-direction: column;
    gap: 8px;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 24px;
    transition: border-color 0.3s, transform 0.3s var(--ease-quint), box-shadow 0.3s;
  }
  .numcard:hover {
    border-color: var(--brass);
    transform: translateY(-3px);
    box-shadow: 0 18px 40px -30px rgba(15, 47, 40, 0.45);
  }
  .numcard__n {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
    color: var(--brass);
    letter-spacing: 0.02em;
  }
  .numcard__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.15rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--forest);
  }
  .numcard__desc {
    font-size: 13.5px;
    color: var(--muted-2);
    line-height: 1.55;
  }
  .numcard__more {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-top: auto;
    padding-top: 8px;
    font-size: 13px;
    font-weight: 700;
    color: var(--brass-dark);
  }

  /* ---- 3. WHY (dark green) ---- */
  .why {
    background: var(--forest);
    color: var(--cream);
    padding: clamp(56px, 8vw, 100px) var(--pad-x);
  }
  .why__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(36px, 5vw, 72px);
    align-items: center;
  }
  @media (max-width: 900px) {
    .why__inner { grid-template-columns: 1fr; gap: 36px; }
  }
  .why__eyebrow {
    color: var(--brass);
    margin-bottom: 16px;
  }
  .why__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--cream);
    max-width: 16ch;
  }
  .why__lead {
    margin: 20px 0 28px;
    font-size: 16px;
    line-height: 1.65;
    color: rgba(246, 241, 231, 0.82);
    max-width: 46ch;
  }
  .why__cards {
    display: grid;
    gap: 12px;
  }
  .why__card {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    background: rgba(246, 241, 231, 0.05);
    border: 1px solid rgba(246, 241, 231, 0.12);
    border-radius: var(--radius);
    padding: 20px 22px;
  }
  .why__card-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--cream);
    margin-bottom: 4px;
  }
  .why__card-desc {
    font-size: 13.5px;
    color: rgba(246, 241, 231, 0.72);
    line-height: 1.55;
  }

  /* ---- 4. PROCESS ---- */
  .steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  @media (max-width: 820px) {
    .steps { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 460px) {
    .steps { grid-template-columns: 1fr; }
  }
  .step__n {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: var(--forest);
    color: var(--cream);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.15rem;
    margin-bottom: 16px;
  }
  .step__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.2rem;
    letter-spacing: -0.01em;
    color: var(--forest);
    margin-bottom: 8px;
  }
  .step__desc {
    font-size: 14px;
    color: var(--muted-2);
    line-height: 1.55;
    max-width: 26ch;
  }

  /* ---- 5. ABOUT ---- */
  .about {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(32px, 5vw, 64px);
    align-items: center;
  }
  @media (max-width: 860px) {
    .about { grid-template-columns: 1fr; }
  }
  .about__placeholder {
    aspect-ratio: 4 / 5;
    max-width: 400px;
    border: 1px dashed var(--line-strong);
    border-radius: var(--radius-lg);
    background: var(--card);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    text-align: center;
    padding: 24px;
  }
  .about__placeholder span {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--muted);
  }
  .about__placeholder small {
    font-size: 13px;
    color: var(--faint);
    max-width: 24ch;
  }
  .about__title { margin: 14px 0 16px; }
  .about__lead {
    font-size: 16px;
    color: var(--muted);
    line-height: 1.65;
    max-width: 52ch;
    margin-bottom: 26px;
  }
  .about__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
  }

  /* ---- 6. PROOF ---- */
  .proof {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
    gap: 14px;
  }
  .proof__card {
    display: flex;
    align-items: center;
    gap: 13px;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 20px 22px;
  }
  .proof__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--forest);
  }

  /* ---- 7. SERVICE AREAS ---- */
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 10px 18px;
    border: 1px solid var(--line);
    background: var(--card);
    border-radius: 999px;
    font-size: 14.5px;
    font-weight: 600;
    color: var(--muted);
  }
  .chip--hq {
    border-color: var(--brass);
    background: var(--lime-08);
    color: var(--forest);
    font-weight: 700;
  }
  .chip__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--brass);
  }
  .chips__cta { margin-top: 32px; }

  /* ---- 8. FAQ ---- */
  .faq {
    max-width: 820px;
    margin: 0 auto;
  }
</style>
