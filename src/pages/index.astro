---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import CallButton from '../components/CallButton.astro';
import AssetImg from '../components/AssetImg.astro';
import Icon from '../components/Icon.astro';
import { business } from '../data/site';

const heroTrust = ['Licensed QBCC plumber', 'Fast local response', 'Clear upfront pricing', 'Local to Birkdale & the bay'];

const services = [
  { icon: 'drain', img: '/assets/blocked-drain.jpg', t: 'Blocked Drains', d: 'Sinks, showers, toilets and sewer lines cleared fast.' },
  { icon: 'hotwater', img: '/assets/hot-water.jpg', t: 'Hot Water', d: 'Repairs, replacements and new installs for hot water systems.' },
  { icon: 'tap', img: '/assets/leaking-tap.jpg', t: 'Leaking Taps', d: 'Dripping taps, running toilets and cistern issues sorted.' },
  { icon: 'leak', img: '/assets/leaking-pipe.jpg', t: 'Leaking Pipes', d: 'Burst and leaking pipes located and repaired properly.' },
  { icon: 'maintenance', img: '/assets/plumber-homeowner.jpg', t: 'General Maintenance', d: 'Ongoing repairs and the everyday jobs that keep a place running.' },
  { icon: 'bolt', img: '/assets/emergency-plumber.jpg', t: 'Emergency Plumbing', d: 'Fast local help for urgent leaks, blockages and plumbing issues.' },
];

const trustCards = [
  { icon: 'shield', t: 'Licensed QBCC plumber' },
  { icon: 'dollar', t: 'Upfront pricing' },
  { icon: 'bolt', t: 'Payment plans available' },
  { icon: 'pin', t: 'Local Birkdale plumber' },
  { icon: 'check', t: 'Clean, respectful work' },
  { icon: 'insured', t: 'Public liability insured' },
];

const suburbs = ['Birkdale', 'Wellington Point', 'Cleveland', 'Capalaba', 'Victoria Point', 'Wynnum', 'Manly', 'Redlands'];

// Trust standards shown until real Google reviews exist (no fabricated reviews).
const trustExpect = [
  { icon: 'quote', t: 'Clear communication', d: 'Straight answers, clear options and pricing before work starts.' },
  { icon: 'check', t: 'Tidy workmanship', d: 'We respect your home and clean up properly after the job.' },
  { icon: 'pin', t: 'Reliable local service', d: 'Based near Birkdale and servicing Bayside Brisbane and the Redlands.' },
  { icon: 'shield', t: 'Practical solutions', d: "We focus on fixing the issue properly, not selling what you don't need." },
];

const footerThumbs = ['/assets/blocked-drain.jpg', '/assets/hot-water.jpg', '/assets/leaking-pipe.jpg', '/assets/emergency-plumber.jpg'];
---
<Layout
  title="S&W Plumbing | Local Plumber Birkdale & Bayside Brisbane"
  description="Fast local plumbing across Birkdale, Bayside Brisbane and the Redlands. Leaks, taps, toilets, hot water, blocked drains and urgent repairs with clear pricing before work starts."
>
  <!-- ===== 1. HERO ===== -->
  <section class="hero">
    <div class="hero__inner container">
      <div class="hero__copy">
        <div class="hero__badge"><span class="hero__badge-dot"></span> Birkdale &amp; Bayside Brisbane Plumber</div>
        <h1 class="hero__title">Fast <span class="hl">local plumbing</span>, done properly.</h1>
        <p class="hero__sub">
          Leaks, taps, toilets, hot water, blocked drains and urgent repairs — handled by a local
          plumber with clear pricing before work starts.
        </p>
        <div class="hero__ctas">
          <CallButton size="lg" />
          <a href="#enquiry" class="btn-ghost-l">Get a quote</a>
        </div>
        <ul class="hero__trust">
          {heroTrust.map((t) => <li><Icon name="check" size={15} stroke="#00A651" /> {t}</li>)}
        </ul>
      </div>

      <div class="hero__visual">
        <span class="hero__accent hero__accent--blue"></span>
        <span class="hero__accent hero__accent--orange"></span>
        <div class="hero__imgcard">
          <AssetImg src="/assets/hero-plumber-home.jpg" alt="S&W plumber greeting a homeowner at a Brisbane home" eager />
          <span class="hero__fbadge hero__fbadge--tl"><span class="dot"></span> Fast local response</span>
          <span class="hero__fbadge hero__fbadge--br">Licensed QBCC plumber · Birkdale local</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 2. BOOKING / QUOTE FORM (overlaps hero) ===== -->
  <div class="bookwrap">
    <div id="enquiry" class="bookcard container">
      <div class="bookcard__head">
        <span class="bookcard__eyebrow">Free quote</span>
        <h2 class="bookcard__title">Tell us what's going on</h2>
        <p class="bookcard__sub">Send the details and we'll get back to you as soon as possible. For urgent jobs, call now.</p>
      </div>
      <ContactForm submitLabel="Get My Quote" compact />
      <ul class="bookcard__trust">
        <li><Icon name="check" size={14} stroke="#00A651" /> Fast response</li>
        <li><Icon name="check" size={14} stroke="#00A651" /> Local plumber</li>
        <li><Icon name="check" size={14} stroke="#00A651" /> Upfront pricing</li>
      </ul>
    </div>
  </div>

  <!-- ===== 3. EMERGENCY STRIP ===== -->
  <section class="emerg">
    <div class="container emerg__inner">
      <div class="emerg__text">
        <span class="emerg__badge"><Icon name="bolt" size={24} stroke="#19C463" /></span>
        <div>
          <div class="emerg__k">After-Hours Emergency Help</div>
          <p class="emerg__sub">Mon–Fri 7am–5pm · Sat by appointment · limited after-hours — call and we'll sort a time.</p>
        </div>
      </div>
      <div class="emerg__ctas">
        <a href={business.phoneHref} class="btn-orange"><Icon name="phone" size={18} /> Call Now</a>
        <a href="/#enquiry" class="btn-outline-l">Get a Quote</a>
      </div>
    </div>
  </section>

  <!-- ===== 4. SERVICES GRID (image-led) ===== -->
  <section class="section svc" id="services" style="background:var(--bg-2)">
    <div class="container">
      <div class="head head--center">
        <div class="eyebrow">What we do</div>
        <h2 class="h2">Plumbing services across Brisbane &amp; Bayside</h2>
        <p class="head__sub">From urgent repairs to everyday maintenance — one local team for the lot, priced upfront.</p>
      </div>
      <div class="svc__grid" data-anim-children>
        {
          services.map((s) => (
            <a href="/services" class="svc__card">
              <div class="svc__media">
                <AssetImg src={s.img} alt={`${s.t} — S&W Plumbing`} />
                <span class="svc__badge"><Icon name={s.icon} size={20} stroke="#FFFFFF" /></span>
              </div>
              <div class="svc__body">
                <h3 class="svc__t">{s.t}</h3>
                <p class="svc__d">{s.d}</p>
                <span class="svc__link">Book now <Icon name="arrow" size={13} stroke="#00A651" /></span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== 5. WHY CHOOSE (team image + trust) ===== -->
  <section class="section why" id="why" style="background:var(--blue-soft)">
    <div class="container why__inner">
      <div class="why__media">
        <AssetImg src="/assets/team-plumbers.jpg" alt="The S&W Plumbing team in Brisbane" class="why__img" />
      </div>
      <div class="why__copy">
        <div class="eyebrow">Why S&amp;W</div>
        <h2 class="why__title">A real local team you can trust with your home.</h2>
        <p class="why__lead">
          You deal directly with local Brisbane plumbers — clear advice, upfront pricing and work done
          properly, every job.
        </p>
        <div class="why__cards" data-anim-children>
          {
            trustCards.map((c) => (
              <div class="why__card">
                <span class="why__icon"><Icon name={c.icon} size={18} stroke="#00A651" /></span>
                <span class="why__t">{c.t}</span>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 6. EMERGENCY CTA (video/image background) ===== -->
  <section class="ecta">
    <video class="ecta__media" autoplay muted loop playsinline poster="/assets/emergency-plumber.jpg?v=2">
      <source src="/assets/hero-emergency-video.mp4" type="video/mp4" />
    </video>
    <span class="ecta__overlay"></span>
    <div class="container ecta__inner">
      <h2 class="ecta__t">Need a plumber today?</h2>
      <p class="ecta__d">Fast local help across Birkdale, Bayside Brisbane and the Redlands.</p>
      <div class="ecta__ctas">
        <a href={business.phoneHref} class="btn-orange btn--xl"><Icon name="phone" size={20} /> Call {business.phone}</a>
        <a href="/#enquiry" class="btn-outline-l btn--xl">Get Quote</a>
      </div>
    </div>
  </section>

  <!-- ===== 7. LOCAL / BRISBANE (van image split) ===== -->
  <section class="section local">
    <div class="container local__inner">
      <div class="local__copy">
        <div class="eyebrow">Local &amp; trusted</div>
        <h2 class="h2 local__title">Servicing Brisbane &amp; the surrounding suburbs</h2>
        <p class="local__d">
          Our vans are out across Brisbane and Bayside every day. Wherever you are, you'll get a local
          plumber who knows the area and turns up when booked.
        </p>
        <div class="local__chips">
          {suburbs.map((s) => <span class="chip">{s}</span>)}
        </div>
        <div class="local__ctas">
          <a href={business.phoneHref} class="btn-orange"><Icon name="phone" size={18} /> Call Now</a>
          <a href="/service-areas" class="btn-ghost-l">Check your suburb</a>
        </div>
      </div>
      <div class="local__media">
        <AssetImg src="/assets/brisbane-service-van.jpg" alt="S&W Plumbing service van in a Brisbane suburb" class="local__img" />
      </div>
    </div>
  </section>

  <!-- ===== 9. WHAT YOU CAN EXPECT (trust, not fake reviews) ===== -->
  <section class="section reviews" id="reviews" style="background:var(--bg-2)">
    <div class="container reviews__inner">
      <div class="reviews__media">
        <AssetImg src="/assets/testimonial-homeowner.jpg" alt="S&W plumber talking with a local homeowner at the door" class="reviews__img" />
        <div class="reviews__stat">
          <span class="reviews__dot"></span>
          <span>Local &amp; trusted · Birkdale</span>
        </div>
      </div>
      <div class="reviews__col">
        <div class="eyebrow">Local standards</div>
        <h2 class="h2 reviews__h">What you can expect from S&amp;W Plumbing</h2>
        <div class="expect__grid" data-anim-children>
          {
            trustExpect.map((c) => (
              <div class="expect">
                <span class="expect__icon"><Icon name={c.icon} size={18} stroke="#00A651" /></span>
                <div>
                  <h3 class="expect__t">{c.t}</h3>
                  <p class="expect__d">{c.d}</p>
                </div>
              </div>
            ))
          }
        </div>
        <p class="reviews__note">Real customer reviews will be added once available.</p>
      </div>
    </div>
  </section>

  <!-- ===== 10. FOOTER IMAGE STRIP ===== -->
  <div class="fstrip">
    {footerThumbs.map((src, i) => (
      <div class="fstrip__cell"><AssetImg src={src} alt={`S&W Plumbing work ${i + 1}`} /></div>
    ))}
  </div>
</Layout>

<style>
  /* ---- buttons ---- */
  .btn-orange {
    display: inline-flex; align-items: center; gap: 10px;
    background: var(--orange); color: #fff; font-weight: 700; font-size: 1.05rem;
    padding: 15px 28px; border-radius: 999px;
    box-shadow: 0 10px 24px -12px rgba(0, 166, 81, 0.6);
    transition: background 0.25s, transform 0.25s;
  }
  .btn-orange:hover { background: var(--orange-dark); transform: translateY(-2px); }
  .btn-ghost-l {
    display: inline-flex; align-items: center; gap: 9px;
    border: 1.5px solid var(--blue); color: var(--blue); background: #fff;
    font-weight: 700; font-size: 1.05rem; padding: 14px 26px; border-radius: 999px;
    transition: border-color 0.25s, background 0.25s, color 0.25s;
  }
  .btn-ghost-l:hover { background: var(--blue); color: #fff; }
  .btn-outline-l {
    display: inline-flex; align-items: center; gap: 9px;
    border: 1.5px solid rgba(255, 255, 255, 0.55); color: #fff;
    font-weight: 700; font-size: 1.05rem; padding: 14px 26px; border-radius: 999px;
    transition: border-color 0.25s, background 0.25s;
  }
  .btn-outline-l:hover { border-color: #fff; background: rgba(255, 255, 255, 0.1); }
  .btn--xl { font-size: 1.15rem; padding: 18px 34px; }

  .head { margin-bottom: 48px; }
  .head--center { text-align: center; max-width: 720px; margin-inline: auto; }
  .head .eyebrow { margin-bottom: 14px; }
  .head__sub { margin-top: 14px; font-size: 16px; color: var(--muted-2); line-height: 1.6; max-width: 54ch; margin-inline: auto; }

  /* ---- 1. HERO ---- */
  .hero {
    position: relative;
    overflow: hidden;
    color: var(--ink);
    padding: calc(clamp(96px, 13vh, 150px) + 24px) var(--pad-x) clamp(90px, 12vw, 150px);
    background: linear-gradient(135deg, #f5faff 0%, #ffffff 45%, #eaf8f0 100%);
  }
  .hero__inner {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.02fr 0.98fr;
    gap: clamp(32px, 5vw, 64px);
    align-items: center;
  }
  @media (max-width: 940px) {
    .hero__inner { grid-template-columns: 1fr; gap: 32px; }
  }
  .hero__badge {
    display: inline-flex; align-items: center; gap: 9px;
    background: #fff; border: 1px solid var(--blue-border); color: var(--blue);
    font-size: 12.5px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase;
    padding: 8px 15px; border-radius: 999px; margin-bottom: 22px;
  }
  .hero__badge-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--orange); }
  .hero__title {
    font-family: var(--font-display); font-weight: 600;
    font-size: clamp(2.5rem, 6vw, 4.4rem); line-height: 1.02; letter-spacing: -0.025em;
    color: var(--ink); max-width: 15ch;
  }
  .hero__title .hl { color: var(--blue); }
  .hero__sub {
    margin-top: 20px; font-size: clamp(1.05rem, 2vw, 1.25rem); color: var(--muted);
    max-width: 48ch; line-height: 1.6;
  }
  .hero__ctas { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 30px; }
  .hero__trust {
    list-style: none; display: grid; grid-template-columns: 1fr 1fr; gap: 10px 20px;
    margin-top: 30px; max-width: 460px;
  }
  .hero__trust li {
    display: flex; align-items: center; gap: 9px; font-size: 14.5px; font-weight: 600; color: var(--text);
  }
  /* hero visual */
  .hero__visual { position: relative; }
  .hero__accent {
    position: absolute; border-radius: 40% 60% 55% 45%; filter: blur(6px); z-index: 0;
  }
  .hero__accent--blue {
    width: 62%; height: 78%; right: -6%; top: -8%;
    background: radial-gradient(circle at 50% 50%, rgba(0, 166, 81, 0.22), transparent 70%);
  }
  .hero__accent--orange {
    width: 38%; height: 40%; left: -4%; bottom: -6%;
    background: radial-gradient(circle at 50% 50%, rgba(0, 166, 81, 0.2), transparent 70%);
  }
  .hero__imgcard {
    position: relative; z-index: 1;
    aspect-ratio: 5 / 4;
    border-radius: 26px; overflow: hidden;
    box-shadow: 0 40px 80px -40px rgba(5, 7, 8, 0.5);
    border: 5px solid #fff;
  }
  @media (max-width: 940px) { .hero__imgcard { aspect-ratio: 16 / 11; } }
  .hero__fbadge {
    position: absolute; z-index: 2;
    display: inline-flex; align-items: center; gap: 8px;
    background: rgba(255, 255, 255, 0.95); color: var(--ink);
    font-size: 12.5px; font-weight: 700; padding: 9px 14px; border-radius: 999px;
    box-shadow: 0 12px 24px -14px rgba(5, 7, 8, 0.5);
  }
  .hero__fbadge .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--orange); }
  .hero__fbadge--tl { top: 16px; left: 16px; }
  .hero__fbadge--br { bottom: 16px; right: 16px; color: var(--blue); }

  /* ---- 2. BOOKING CARD ---- */
  .bookwrap { position: relative; z-index: 5; padding: 0 var(--pad-x); margin-top: clamp(-70px, -6vw, -48px); }
  .bookcard {
    background: #fff; border: 1px solid var(--line); border-top: 4px solid var(--blue);
    border-radius: 24px; padding: clamp(24px, 3vw, 36px); max-width: 900px;
    box-shadow: 0 40px 80px -44px rgba(5, 7, 8, 0.4);
    scroll-margin-top: 120px;
  }
  .bookcard__head { margin-bottom: 20px; }
  .bookcard__eyebrow {
    display: inline-block; font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    font-weight: 800; color: var(--green-dark); background: var(--green-light);
    padding: 5px 11px; border-radius: 999px; margin-bottom: 12px;
  }
  .bookcard__title {
    font-family: var(--font-display); font-weight: 700; font-size: 1.7rem; color: var(--ink); letter-spacing: -0.01em; line-height: 1.1;
  }
  .bookcard__sub { margin-top: 8px; font-size: 14.5px; color: var(--muted-2); line-height: 1.5; max-width: 46ch; }
  .bookcard__trust {
    list-style: none; display: flex; flex-wrap: wrap; gap: 10px 24px;
    margin-top: 18px; padding-top: 18px; border-top: 1px solid var(--line);
  }
  .bookcard__trust li { display: inline-flex; align-items: center; gap: 7px; font-size: 13.5px; font-weight: 600; color: var(--muted); }

  /* ---- 3. EMERGENCY STRIP ---- */
  .emerg {
    background: linear-gradient(100deg, var(--black) 0%, var(--charcoal) 58%, #0e2c1e 100%);
    color: #fff;
    padding: clamp(26px, 3.4vw, 38px) var(--pad-x);
    border-top: 2px solid var(--green);
  }
  .emerg__inner { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 20px; }
  .emerg__text { display: flex; align-items: center; gap: 16px; }
  .emerg__badge {
    display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0;
    width: 52px; height: 52px; border-radius: 14px;
    background: rgba(25, 196, 99, 0.14); border: 1px solid rgba(25, 196, 99, 0.35); color: var(--green-bright);
  }
  .emerg__k {
    font-family: var(--font-body); font-weight: 800;
    font-size: clamp(1.2rem, 2.6vw, 1.6rem); letter-spacing: -0.01em; line-height: 1.2;
  }
  .emerg__sub { margin-top: 3px; font-size: 14.5px; color: rgba(255, 255, 255, 0.7); }
  .emerg__ctas { display: flex; flex-wrap: wrap; gap: 12px; }

  /* ---- 4. SERVICES GRID ---- */
  .svc__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  @media (max-width: 900px) { .svc__grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .svc__grid { grid-template-columns: 1fr; } }
  .svc__card {
    display: block; background: var(--card); border: 1px solid var(--line);
    border-radius: 18px; overflow: hidden;
    box-shadow: 0 12px 30px -24px rgba(16, 20, 18, 0.5);
    transition: transform 0.35s var(--ease-quint), box-shadow 0.35s, border-color 0.35s;
  }
  .svc__card:hover {
    transform: translateY(-6px); border-color: rgba(0, 166, 81, 0.55);
    box-shadow: 0 34px 60px -34px rgba(11, 40, 26, 0.55);
  }
  .svc__media { position: relative; height: 210px; overflow: hidden; }
  @media (max-width: 560px) { .svc__media { height: 190px; } }
  .svc__media :global(img) { transition: transform 0.7s var(--ease-quint); }
  .svc__card:hover .svc__media :global(img) { transform: scale(1.07); }
  /* subtle bottom gradient so the image feels composed, not just placed */
  .svc__media::after {
    content: ''; position: absolute; inset: 0; pointer-events: none;
    background: linear-gradient(to top, rgba(5, 7, 8, 0.5) 0%, rgba(5, 7, 8, 0.12) 30%, transparent 55%);
  }
  .svc__badge {
    position: absolute; top: 14px; left: 14px; z-index: 2;
    display: inline-flex; align-items: center; justify-content: center;
    width: 44px; height: 44px; border-radius: 12px; background: var(--green); color: #fff;
    box-shadow: 0 8px 18px -8px rgba(0, 166, 81, 0.8);
  }
  .svc__body { padding: 22px 22px 24px; }
  .svc__t { font-family: var(--font-display); font-weight: 600; font-size: 1.35rem; color: var(--navy); margin-bottom: 8px; }
  .svc__d { font-size: 14.5px; color: var(--muted-2); line-height: 1.6; margin-bottom: 14px; }
  .svc__link { display: inline-flex; align-items: center; gap: 7px; font-size: 14px; font-weight: 700; color: var(--orange-dark); }

  /* ---- 5. WHY ---- */
  .why__inner {
    display: grid; grid-template-columns: 0.95fr 1.05fr; gap: clamp(32px, 5vw, 64px); align-items: center;
  }
  @media (max-width: 900px) { .why__inner { grid-template-columns: 1fr; } }
  .why__media {
    border-radius: 24px; overflow: hidden; aspect-ratio: 4 / 3;
    box-shadow: 0 40px 70px -40px rgba(5, 7, 8, 0.45); border: 5px solid #fff;
  }
  .why__img { height: 100%; }
  .why__title { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.8rem, 4vw, 2.7rem); color: var(--ink); letter-spacing: -0.02em; margin: 12px 0 12px; max-width: 18ch; }
  .why__lead { font-size: 16px; color: var(--muted); line-height: 1.6; max-width: 48ch; margin-bottom: 22px; }
  .why__cards { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  @media (max-width: 480px) { .why__cards { grid-template-columns: 1fr; } }
  .why__card {
    display: flex; align-items: center; gap: 12px; background: #fff; border: 1px solid var(--line);
    border-radius: 12px; padding: 15px 16px;
  }
  .why__icon {
    display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0;
    width: 38px; height: 38px; border-radius: 10px; background: var(--lime-10); color: var(--blue);
  }
  .why__t { font-weight: 600; font-size: 14.5px; color: var(--navy); }

  /* ---- 6. EMERGENCY CTA (video/image bg) ---- */
  .ecta {
    position: relative; overflow: hidden; background: var(--navy);
    padding: clamp(64px, 9vw, 120px) var(--pad-x); text-align: center; color: #fff;
  }
  .ecta__media { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; }
  .ecta__overlay {
    position: absolute; inset: 0; z-index: 1;
    background: linear-gradient(180deg, rgba(5, 7, 8, 0.82), rgba(5, 7, 8, 0.9));
  }
  .ecta__inner { position: relative; z-index: 2; max-width: 720px; margin: 0 auto; }
  .ecta__t { font-family: var(--font-display); font-weight: 600; font-size: clamp(2rem, 5vw, 3.4rem); color: #fff; letter-spacing: -0.02em; }
