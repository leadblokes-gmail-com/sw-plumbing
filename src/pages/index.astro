---
import Layout from '../layouts/Layout.astro';
import Section from '../components/Section.astro';
import SectionHeading from '../components/SectionHeading.astro';
import Credentials from '../components/Credentials.astro';
import Accordion from '../components/Accordion.astro';
import CallButton from '../components/CallButton.astro';
import Icon from '../components/Icon.astro';
import { business, faqs, suburbs } from '../data/site';

// Hero quick-help list + the six things people actually call about.
const helpNow = ['Burst pipe or leak', 'Blocked toilet', 'No hot water', 'Tap or cistern repair'];

const fixes = [
  { icon: 'drain', title: 'Blocked drains & toilets', blurb: 'Cleared properly — back to flowing without the mess.' },
  { icon: 'leak', title: 'Burst pipes & leaks', blurb: 'Isolated and repaired to stop the damage and the water bill.' },
  { icon: 'hotwater', title: 'Hot water systems', blurb: 'Repairs and installs — back to hot showers.' },
  { icon: 'tap', title: 'Taps, toilets & cisterns', blurb: 'No more drips, runs or wobbly handles.' },
  { icon: 'gas', title: 'Gas fitting', blurb: 'Gas appliances and fittings handled safely and to code.' },
  { icon: 'maintenance', title: 'Maintenance plumbing', blurb: 'The ongoing jobs that keep a home or rental running.' },
];

const meetPoints = [
  'Homes, rentals and small businesses',
  'Maintenance and repair plumbing',
  'Clear communication before work begins',
  'Clean, respectful service',
];

const overview = [
  'Blocked drains', 'Burst pipes & leaks', 'Hot water', 'Taps & toilets',
  'Gas fitting', 'Roof & gutter leaks', 'Bathroom & reno', 'General maintenance',
];

const faqSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((f) => ({
      '@type': 'Question',
      name: f.q,
      acceptedAnswer: { '@type': 'Answer', text: f.a },
    })),
  },
];
---
<Layout
  title="S&W Plumbing | Plumber Birkdale & Bayside Brisbane"
  description="Local plumber servicing Birkdale, Wynnum, Cleveland, Wellington Point and Bayside Brisbane. Leaks, taps, toilets, hot water, burst pipes and maintenance plumbing. Clear pricing before work starts — call 0432 292 371."
  intro={true}
  schema={faqSchema}
>
  <!-- ===== 1. HERO ===== -->
  <section class="hero">
    <div class="hero__media" aria-hidden="true">
      <img src="/images/hero-bg.webp" alt="" width="1920" height="1080" fetchpriority="high" />
    </div>
    <div class="hero__veil"></div>

    <div class="hero__inner container">
      <div class="hero__copy">
        <div data-hero class="badge">
          <span class="badge__dot"></span>
          <span>Birkdale plumber · Bayside Brisbane</span>
        </div>

        <h1 class="hero__title hero-mask">
          <span class="reveal-line"><span>Local plumbing,</span></span>
          <span class="reveal-line"><span>done <em class="kinetic">properly</em>.</span></span>
        </h1>

        <p data-hero class="hero__sub">
          Leaks, taps, toilets, hot water, burst pipes and maintenance plumbing across Birkdale,
          Bayside Brisbane and the Redlands.
        </p>

        <div data-hero class="hero__ctas">
          <CallButton size="lg" />
          <a href="/services" class="btn-ghost" data-magnetic>
            View services
            <Icon name="arrow" size={18} stroke="#B6FF3C" />
          </a>
        </div>

        <p data-hero class="hero__trust">
          Clear pricing before work starts · Clean, tidy work · Local response where available
        </p>
      </div>

      <aside data-hero class="hero__card" aria-label="Need help today?">
        <h2 class="hero__card-title">Need help today?</h2>
        <ul class="hero__card-list">
          {helpNow.map((h) => (
            <li><Icon name="check" size={15} stroke="#B6FF3C" /> {h}</li>
          ))}
        </ul>
        <CallButton size="md" label="Call now" />
        <p class="hero__card-note"><span class="badge__dot"></span> Based near Birkdale</p>
      </aside>
    </div>
  </section>

  <!-- ===== 2. PROBLEM SELECTOR ===== -->
  <Section id="services">
    <SectionHeading eyebrow="What do you need fixed?" max="620px">
      Tell us what's gone wrong.
    </SectionHeading>
    <div class="fixes" data-anim-children>
      {
        fixes.map((f) => (
          <a href={business.phoneHref} class="fix">
            <div class="fix__top">
              <span class="fix__icon"><Icon name={f.icon} size={22} stroke="#B6FF3C" /></span>
              <h3 class="fix__title">{f.title}</h3>
            </div>
            <p class="fix__blurb">{f.blurb}</p>
            <span class="fix__call">Call about this <Icon name="arrow" size={13} stroke="#B6FF3C" /></span>
          </a>
        ))
      }
    </div>
  </Section>

  <!-- ===== 3. PROOF OVER PROMISES ===== -->
  <Section tint>
    <SectionHeading eyebrow="Why S&amp;W" max="640px">Proof over promises.</SectionHeading>
    <p data-reveal class="lead">
      We're building S&amp;W on clear communication, upfront pricing and clean, careful work. Real
      reviews and project photos can be added as they come in — no fake quotes, no made-up stars.
    </p>
    <Credentials />
  </Section>

  <!-- ===== 4. MEET YOUR LOCAL PLUMBER ===== -->
  <Section>
    <div class="meet">
      <div data-reveal class="meet__media">
        <div class="meet__placeholder">
          <Icon name="pin" size={26} stroke="#B6FF3C" />
          <span>Owner photo to be added</span>
          <small>A real photo of your local plumber goes here.</small>
        </div>
      </div>
      <div data-reveal class="meet__copy">
        <div class="eyebrow">Your local plumber</div>
        <h2 class="h2 meet__title">Deal directly with your local plumber.</h2>
        <p class="meet__lead">
          S&amp;W Plumbing is based near Birkdale and services Bayside Brisbane and the Redlands.
          You'll deal directly with a local plumber who explains the work clearly, prices it before
          starting and leaves the place tidy.
        </p>
        <ul class="meet__points">
          {meetPoints.map((p) => (
            <li><Icon name="check" size={16} stroke="#B6FF3C" /> {p}</li>
          ))}
        </ul>
        <div class="meet__cta"><CallButton size="md" /></div>
      </div>
    </div>
  </Section>

  <!-- ===== 5. SERVICES OVERVIEW ===== -->
  <Section tint>
    <div class="over">
      <div data-reveal class="over__copy">
        <div class="eyebrow">Services</div>
        <h2 class="h2 over__title">Plumbing services across the bay.</h2>
        <p class="over__text">
          From small repairs to urgent plumbing issues, S&amp;W handles the everyday jobs that keep
          homes, rentals and businesses running.
        </p>
        <a href="/services" class="btn-ghost" data-magnetic>
          View all services <Icon name="arrow" size={17} stroke="#B6FF3C" />
        </a>
      </div>
      <ul data-reveal class="over__list">
        {overview.map((s) => (
          <li><a href="/services"><Icon name="check" size={15} stroke="#B6FF3C" /> {s}</a></li>
        ))}
      </ul>
    </div>
  </Section>

  <!-- ===== 6. SERVICE AREAS ===== -->
  <Section id="areas">
    <SectionHeading eyebrow="Service areas" max="720px">
      Based near Birkdale. Servicing Bayside Brisbane and the Redlands.
    </SectionHeading>
    <div class="chips" data-reveal>
      {
        suburbs.map((s) => (
          <span class:list={['chip', { 'chip--hq': s.hq }]}>
            {s.hq && <span class="chip__dot" />}
            {s.name}
          </span>
        ))
      }
    </div>
    <a href="/service-areas" class="btn-ghost chips__cta" data-magnetic data-reveal>
      Check your suburb <Icon name="arrow" size={17} stroke="#B6FF3C" />
    </a>
  </Section>

  <!-- ===== 7. FAQ ===== -->
  <Section tint>
    <div class="faq">
      <SectionHeading eyebrow="Good to know" max="820px">Common questions.</SectionHeading>
      <Accordion items={faqs} />
    </div>
  </Section>

  <!-- ===== 8. COMPACT CTA ===== -->
  <section class="endcta">
    <div class="container endcta__inner">
      <div data-reveal class="endcta__copy">
        <h2 class="endcta__title">Need a plumber in Bayside Brisbane?</h2>
        <p class="endcta__sub">Call S&amp;W Plumbing and we'll talk you through the next step.</p>
      </div>
      <div data-reveal class="endcta__btn"><CallButton size="lg" /></div>
    </div>
  </section>
</Layout>

<style>
  /* ---- shared primitives ---- */
  .badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 7px 14px;
    border: 1px solid var(--line);
    background: rgba(20, 24, 28, 0.6);
    border-radius: 999px;
    margin-bottom: 24px;
    font-size: 12.5px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted-2);
    font-weight: 600;
  }
  .badge__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--lime);
  }
  .btn-ghost {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    border: 1px solid var(--line-strong);
    background: rgba(20, 24, 28, 0.5);
    color: var(--text);
    font-weight: 600;
    font-size: 1rem;
    padding: 15px 24px;
    border-radius: 999px;
    white-space: nowrap;
    transition: border-color 0.3s, background 0.3s;
  }
  .btn-ghost:hover {
    border-color: var(--lime);
    background: var(--lime-08);
  }
  .lead {
    margin: -30px 0 44px;
    max-width: 60ch;
    font-size: 16px;
    color: var(--muted-2);
    line-height: 1.65;
  }

  /* ---- 1. HERO (two-column) ---- */
  .hero {
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
    min-height: 88vh;
    padding: 130px var(--pad-x) 80px;
  }
  .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.28;
  }
  .hero__veil {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(180deg, rgba(10, 12, 14, 0.82) 0%, rgba(10, 12, 14, 0.6) 50%, var(--ink-900) 100%);
  }
  .hero__inner {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1.35fr 0.85fr;
    gap: clamp(36px, 5vw, 72px);
    align-items: center;
  }
  @media (max-width: 900px) {
    .hero__inner {
      grid-template-columns: 1fr;
    }
  }
  .hero__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(2.7rem, 6.6vw, 5.2rem);
    line-height: 0.98;
    letter-spacing: -0.025em;
  }
  .hero__title em {
    font-style: normal;
    color: var(--lime);
  }
  .hero__sub {
    margin-top: 22px;
    font-size: clamp(1.02rem, 2vw, 1.22rem);
    color: var(--muted);
    max-width: 46ch;
    line-height: 1.55;
  }
  .hero__ctas {
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 32px;
  }
  .hero__trust {
    margin-top: 26px;
    font-size: 13.5px;
    color: var(--muted-2);
    font-weight: 500;
    letter-spacing: 0.01em;
  }
  /* right-side premium card */
  .hero__card {
    background: rgba(16, 19, 22, 0.72);
    border: 1px solid var(--line-strong);
    border-radius: var(--radius-lg);
    padding: 30px;
    backdrop-filter: blur(8px);
  }
  .hero__card-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.4rem;
    letter-spacing: -0.01em;
    margin-bottom: 18px;
  }
  .hero__card-list {
    list-style: none;
    display: grid;
    gap: 12px;
    margin-bottom: 24px;
  }
  .hero__card-list li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 15px;
    font-weight: 500;
    color: var(--text);
  }
  .hero__card-note {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 16px;
    font-size: 13px;
    color: var(--muted-2);
    font-weight: 600;
  }

  /* ---- 2. PROBLEM SELECTOR ---- */
  .fixes {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
  }
  @media (max-width: 820px) {
    .fixes { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 520px) {
    .fixes { grid-template-columns: 1fr; }
  }
  .fix {
    display: flex;
    flex-direction: column;
    gap: 12px;
    background: var(--ink-800);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 22px;
    transition: border-color 0.3s, transform 0.3s var(--ease-quint);
  }
  .fix:hover {
    border-color: rgba(182, 255, 60, 0.4);
    transform: translateY(-2px);
  }
  .fix__top {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .fix__icon {
    width: 40px;
    height: 40px;
    flex-shrink: 0;
    border-radius: 10px;
    background: var(--lime-10);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--lime);
  }
  .fix__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.08rem;
    letter-spacing: -0.01em;
    line-height: 1.15;
  }
  .fix__blurb {
    font-size: 14px;
    color: var(--muted-2);
    line-height: 1.5;
  }
  .fix__call {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    font-weight: 700;
    color: var(--lime);
    margin-top: auto;
  }

  /* ---- 4. MEET ---- */
  .meet {
    display: grid;
    grid-template-columns: 0.85fr 1.15fr;
    gap: clamp(32px, 5vw, 64px);
    align-items: center;
  }
  @media (max-width: 860px) {
    .meet { grid-template-columns: 1fr; }
  }
  .meet__placeholder {
    aspect-ratio: 4 / 5;
    max-width: 420px;
    border: 1px dashed var(--line-strong);
    border-radius: var(--radius-lg);
    background: var(--ink-850);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    text-align: center;
    padding: 24px;
  }
  .meet__placeholder span {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--muted);
  }
  .meet__placeholder small {
    font-size: 13px;
    color: var(--faint);
    max-width: 24ch;
  }
  .meet__title { margin: 14px 0 16px; }
  .meet__lead {
    font-size: 16px;
    color: var(--muted-2);
    line-height: 1.65;
    max-width: 52ch;
  }
  .meet__points {
    list-style: none;
    margin: 22px 0 28px;
    display: grid;
    gap: 11px;
  }
  .meet__points li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 15px;
    font-weight: 500;
    color: var(--text);
  }

  /* ---- 5. SERVICES OVERVIEW ---- */
  .over {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(32px, 5vw, 64px);
    align-items: center;
  }
  @media (max-width: 820px) {
    .over { grid-template-columns: 1fr; }
  }
  .over__title { margin: 14px 0 16px; }
  .over__text {
    font-size: 16px;
    color: var(--muted-2);
    line-height: 1.6;
    max-width: 40ch;
    margin-bottom: 28px;
  }
  .over__list {
    list-style: none;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px 24px;
  }
  .over__list a {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 12px 0;
    border-bottom: 1px solid var(--line);
    font-size: 15px;
    font-weight: 500;
    color: var(--muted);
    transition: color 0.25s;
  }
  .over__list a:hover { color: var(--lime); }

  /* ---- 6. SERVICE AREAS ---- */
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }
  .chip {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 11px 18px;
    border: 1px solid var(--line);
    background: var(--ink-800);
    border-radius: 999px;
    font-size: 14.5px;
    font-weight: 600;
    color: var(--muted);
  }
  .chip--hq {
    border-color: rgba(182, 255, 60, 0.35);
    background: var(--lime-08);
    color: var(--text);
    font-weight: 700;
  }
  .chip__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--lime);
  }
  .chips__cta { margin-top: 34px; }

  /* ---- 7. FAQ ---- */
  .faq {
    max-width: 820px;
    margin: 0 auto;
  }

  /* ---- 8. COMPACT CTA ---- */
  .endcta {
    border-top: 1px solid var(--ink-800);
    padding: clamp(48px, 7vw, 84px) var(--pad-x);
  }
  .endcta__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 28px;
  }
  .endcta__title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.7rem, 4vw, 2.6rem);
    line-height: 1.05;
    letter-spacing: -0.02em;
  }
  .endcta__sub {
    margin-top: 12px;
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: var(--muted-2);
    max-width: 46ch;
  }
</style>
